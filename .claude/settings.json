{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",

	"permissions": {
		"allow": [
			"Read",
			"Edit",
			"Write",
			"NotebookEdit",
			"WebFetch(domain:*)",
			"WebSearch",
			"Bash",
			"BashOutput",
			"KillShell",
			"Glob",
			"Grep",
			"Task",
			"TodoWrite",
			"Skill",
			"Skill(code-review)",
			"Skill(code-review:*)"
		],
		"deny": [],
		"defaultMode": "acceptEdits",
		"additionalDirectories": ["/home/cartago/_projects/mcp-vertex"]
	},

	"skipDangerousModePermissionPrompt": true,

	"defaultMode": "bypassPermissions",

	"env": {
		"BUN_NO_PROMPT": "1",
		"CI": "1"
	},

	"mcpServers": {}
}
