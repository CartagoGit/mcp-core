{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"permissions": {
		"allow": [
			"Read",
			"Edit",
			"Write",
			"WebFetch(domain:*)",
			"Bash",
			"mcp__mcp-vertex__proposals_proposal_board",
			"mcp__mcp-vertex__proposals_state_health",
			"mcp__mcp-vertex__proposals_agent_lock",
			"mcp__mcp-vertex__proposals_compact_status",
			"mcp__mcp-vertex__proposals_continue_proposal"
		],
		"deny": []
	},
	"skipDangerousModePermissionPrompt": true,
	"defaultMode": "bypassPermissions"
}
