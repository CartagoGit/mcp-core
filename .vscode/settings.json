{
	// Format-on-save for the front surface (apps/web/**).
	// The repo formatter is Biome — see /biome.json.
	// Bun is the package manager and runner.
	//
	// To override locally, add to .vscode/settings.local.json (gitignored).

	"editor.formatOnSave": true,
	"editor.defaultFormatter": "biomejs.biome",
	"editor.codeActionsOnSave": {
		"source.fixAll.biome": "explicit"
	},

	// Scope format-on-save to the front (Astro site). Backend packages keep
	// their existing formatter rules; nothing is changed outside apps/web.
	"[astro]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[scss]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[javascript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescriptreact]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[json]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[html]": {
		"editor.defaultFormatter": "biomejs.biome"
	},

	// ──────────────────────────────────────────────────────────────────────
	// Copilot / Copilot Chat / agent mode: auto-approve everything.
	//
	// These settings make VS Code Copilot run without asking for confirmation
	// before tool calls, file edits, terminal commands, or MCP server calls.
	// The repo is a developer sandbox (`AGENTS.md` already declares this a
	// trusted monorepo) so we trade friction for velocity. Override locally
	// by adding the same keys to `.vscode/settings.local.json` (gitignored)
	// and setting them back to false. See `.vscode/settings.local.json.example`
	// for a starter override file.
	// ──────────────────────────────────────────────────────────────────────

	// Auto-approve ALL chat-mode tool calls (file edits, terminal, search,
	// MCP, browser). Equivalent to Claude Code's `bypassPermissions`.
	"chat.tools.autoApprove": true,

	// Don't prompt before running terminal commands from chat.
	"chat.tools.terminal.autoApprove": {
		"*": true,
		"tee": true
	},

	// Don't prompt before running MCP server tools.
	"chat.mcp.autoApprove": true,

	// Don't prompt before file edits / writes from chat.
	"chat.edit.autoApprove": true,

	// Don't prompt before inserting code at the cursor (next-edit suggestions
	// already bypass by default; this covers the inline-chat confirm dialog).
	"chat.inlineChat.acceptChangesWithCtrlEnter": true,
	"chat.inlineChat.disableNotification": true,

	// Auto-approve in the agent (autopilot-like) workflow.
	"github.copilot.chat.agent.autoApprove": true,

	// Don't show the "allow this command" dialog for terminal commands Copilot
	// generates. The terminal still runs; only the prompt is suppressed.
	"github.copilot.chat.runCommand.enabled": true,
	"github.copilot.chat.commandExecution.alwaysAllow": true,

	// Suppress telemetry permission prompts (these are unrelated to chat
	// permissions but they pop up at first session start and add noise).
	"github.copilot.telemetry.enabled": false,

	// ──────────────────────────────────────────────────────────────────────
	// Agent skills — make `mcp-vertex-status-marker-and-closure` discoverable
	// in this workspace so the canonical close-marker behaviour is injected
	// on every response. The skill itself lives at
	// `plugins/status-marker/skills/mcp-vertex-status-marker-and-closure/`
	// and is owned by the `@mcp-vertex/status-marker` plugin (per the SOLID
	// ownership rules in `docs/mcp-vertex/skills/README.md`).
	// Core + transversal skills are added for completeness so the host can
	// discover every skill shipped by the project.
	// ──────────────────────────────────────────────────────────────────────
	"chat.agentSkills.enabled": true,
	"chat.agentSkillsLocations": [
		"./packages/core/skills",
		"./plugins/status-marker/skills",
		"./plugins/proposals/skills",
		"./plugins/audit/skills",
		"./plugins/quality/skills",
		"./plugins/test-convention/skills",
		"./plugins/conventions/skills",
		"./plugins/web-fetch/skills",
		"./plugins/memory/skills",
		"./plugins/docs/skills",
		"./plugins/git/skills",
		"./plugins/search/skills",
		"./plugins/deps/skills",
		"./plugins/notification/skills",
		"./plugins/logs/skills",
		"./plugins/rules/skills",
		"./plugins/issues/skills"
	]
}
