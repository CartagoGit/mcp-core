{
	"name": "@cartago-git/web",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Product/documentation site for @cartago-git/mcp-core, generated from the live tool registry (tools + capabilities.json stay in sync with the code).",
	"scripts": {
		"dev": "astro dev",
		"preview": "astro preview",
		"build": "bun scripts/gen-capabilities.ts && astro build",
		"build:strict": "bun scripts/gen-capabilities.ts --strict && astro build"
	},
	"dependencies": {
		"astro": "^6.4.8",
		"sass": "^1.101.0"
	},
	"devDependencies": {
		"@modelcontextprotocol/sdk": "1.29.0",
		"@cartago-git/mcp-core": "workspace:*",
		"@cartago-git/mcp-proposals": "workspace:*",
		"@cartago-git/mcp-rules": "workspace:*",
		"@cartago-git/mcp-memory": "workspace:*",
		"@cartago-git/mcp-git": "workspace:*",
		"@cartago-git/mcp-quality": "workspace:*",
		"@cartago-git/mcp-search": "workspace:*",
		"@cartago-git/mcp-notification": "workspace:*",
		"@cartago-git/mcp-docs": "workspace:*",
		"@cartago-git/mcp-deps": "workspace:*"
	}
}
