---
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
	lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="concept" class="section">
	<div class="container">
		<h2>{t.concept.title}</h2>
		<p class="lead">{t.concept.body}</p>
		<div class="grid">
			<div class="feature"><h3>{t.concept.f1.t}</h3><p>{t.concept.f1.b}</p></div>
			<div class="feature"><h3>{t.concept.f2.t}</h3><p>{t.concept.f2.b}</p></div>
			<div class="feature"><h3>{t.concept.f3.t}</h3><p>{t.concept.f3.b}</p></div>
			<div class="feature"><h3>{t.concept.f4.t}</h3><p>{t.concept.f4.b}</p></div>
		</div>
	</div>
</section>
