---
import Marquee from './Marquee.astro';
import Config from './Config.astro';
import { runtimes, clients } from '../data/marquees';
import { useTranslations, type Lang } from '../i18n/ui';
import capabilities from '../data/capabilities.json';

interface Props {
	lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const repo = 'https://github.com/CartagoGit/mcp-core';

const NS_LABEL: Record<string, string> = {
	mcpcore: 'core', proposals: 'proposals', git: 'git', memory: 'memory',
	search: 'search', rules: 'rules', quality: 'quality', docs: 'docs',
	deps: 'deps', notification: 'notification',
};

type ITool = { name: string; namespace: string; description: string };
const tools = capabilities.tools as ITool[];
const groups: Record<string, ITool[]> = {};
for (const tool of tools) (groups[tool.namespace] ??= []).push(tool);
const namespaces = Object.entries(groups).sort((a, b) => a[0].localeCompare(b[0]));

const packages = capabilities.packages as Array<{ name: string; version: string }>;
const shortName = (name: string) => name.replace('@cartago-git/mcp-', '').replace('@cartago-git/', '');

// Benchmarks: real payloads measured live (see gen-capabilities.ts) + one
// clearly-labelled illustrative baseline. Bar width is proportional to tokens.
type IBench = { id: string; label: string; bytes: number; tokens: number };
const benches = ((capabilities as { benchmarks?: IBench[] }).benchmarks ?? []) as IBench[];
const benchById = Object.fromEntries(benches.map((b) => [b.id, b]));
const compactTok = benchById.overview_compact?.tokens ?? 0;
const autoTok = benchById.auto_work?.tokens ?? 0;
const coldStartTok = compactTok + autoTok;
const BASELINE_TOK = 4000; // illustrative estimate of orienting by hand
const benchBars = [
	{ name: 'overview (full)', tokens: benchById.overview_full?.tokens ?? 0, kind: '' },
	{ name: 'overview (compact)', tokens: compactTok, kind: '' },
	{ name: 'auto_work', tokens: autoTok, kind: '' },
	{ name: 'compact + auto_work', tokens: coldStartTok, kind: 'is-hl' },
	{ name: t('bench.baseline'), tokens: BASELINE_TOK, kind: 'is-base' },
].filter((b) => b.tokens > 0);
const benchMax = Math.max(1, ...benchBars.map((b) => b.tokens));
---

<nav class="nav">
	<div class="container nav__inner">
		<span class="nav__brand">
			<img class="nav__logo" src={`${base}/logo.svg`} width="26" height="26" alt="" />
			@cartago-git/mcp-core
		</span>
		<div class="nav__links">
			<a href="#concept">{t('nav.concept')}</a>
			<a href="#install">{t('nav.install')}</a>
			<a href="#tools">{t('nav.tools')}</a>
			<a href="#benchmarks">{t('nav.benchmarks')}</a>
			<a href="#plugins">{t('nav.plugins')}</a>
			<a href={`${base}/api/`}>API</a>
			<a href={repo}>{t('nav.github')}</a>
			<button class="gear" id="cfg-open" aria-label={t('cfg.title')}>
				<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<circle cx="12" cy="12" r="3"></circle>
					<path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
				</svg>
			</button>
		</div>
	</div>
</nav>

<header class="hero">
	<div class="container">
		<img class="hero__logo" src={`${base}/logo.svg`} width="76" height="76" alt="mcp-core" />
		<h1>{t('hero.title.a')}<span class="grad">{t('hero.title.b')}</span>{t('hero.title.c')}</h1>
		<p class="tagline">{t('hero.tagline')}</p>
		<div class="ctas">
			<a class="btn btn--primary" href="#install">{t('hero.ctaInstall')}</a>
			<a class="btn btn--ghost" href="#tools">{t('hero.ctaTools')}</a>
		</div>
		<p class="runs">{t('hero.runsOn')} · v{capabilities.coreVersion}</p>
	</div>
</header>

<section class="marquees container">
	<Marquee items={runtimes} label={t('marquee.runtimes')} />
	<Marquee items={clients} label={t('marquee.clients')} reverse />
</section>

<section id="concept" class="section">
	<div class="container">
		<h2>{t('concept.title')}</h2>
		<p class="lead">{t('concept.body')}</p>
		<div class="grid">
			<div class="feature"><h3>{t('concept.f1.t')}</h3><p>{t('concept.f1.b')}</p></div>
			<div class="feature"><h3>{t('concept.f2.t')}</h3><p>{t('concept.f2.b')}</p></div>
			<div class="feature"><h3>{t('concept.f3.t')}</h3><p>{t('concept.f3.b')}</p></div>
			<div class="feature"><h3>{t('concept.f4.t')}</h3><p>{t('concept.f4.b')}</p></div>
		</div>
	</div>
</section>

<section id="install" class="section">
	<div class="container">
		<h2>{t('install.title')}</h2>
		<p class="lead">{t('install.lead')}</p>
		<pre><code>bun add @cartago-git/mcp-core</code></pre>
		<pre><code>{`{
  "servers": {
    "mcp-core": {
      "command": "bunx",
      "args": ["@cartago-git/mcp-core", "--preset=standard"]
    }
  }
}`}</code></pre>
		<p class="lead">{t('install.config')}</p>
	</div>
</section>

<section id="tools" class="section">
	<div class="container">
		<h2>{t('tools.title')}</h2>
		<p class="lead">{t('tools.lead')}</p>
		<div class="stat-row">
			<div class="stat"><b>{capabilities.counts.tools}</b><span>{t('tools.count')}</span></div>
			<div class="stat"><b>{capabilities.counts.packages}</b><span>{t('tools.packages')}</span></div>
		</div>
		{
			namespaces.map(([ns, list]) => (
				<div class="ns">
					<div class="ns__head"><h3>{NS_LABEL[ns] ?? ns}</h3><span class="ns__count">{list.length}</span></div>
					<div class="tools-grid">
						{list.map((tool) => (
							<div class="tool"><code>{tool.name}</code><p>{tool.description}</p></div>
						))}
					</div>
				</div>
			))
		}
	</div>
</section>

<section id="benchmarks" class="section">
	<div class="container">
		<h2>{t('bench.title')}</h2>
		<p class="lead">{t('bench.lead')}</p>
		<div class="grid">
			<div class="feature"><h3>&lt;300 · {t('bench.b1.t')}</h3><p>{t('bench.b1.b')}</p></div>
			<div class="feature"><h3>0 · {t('bench.b2.t')}</h3><p>{t('bench.b2.b')}</p></div>
			<div class="feature"><h3>✓ {t('bench.b3.t')}</h3><p>{t('bench.b3.b')}</p></div>
		</div>
		{
			benchBars.length > 0 && (
				<div class="bench">
					<h3 class="bench__title">{t('bench.live.title')}</h3>
					<div class="bench__chart">
						{benchBars.map((b) => (
							<div class={`bar ${b.kind}`}>
								<span class="bar__label">{b.name}</span>
								<span class="bar__track">
									<span class="bar__fill" style={`width:${Math.max(2, (b.tokens / benchMax) * 100)}%`} />
								</span>
								<span class="bar__val">{b.tokens.toLocaleString()} tok</span>
							</div>
						))}
					</div>
					<p class="bench__note">{t('bench.live.note')}</p>
				</div>
			)
		}
	</div>
</section>

<section id="plugins" class="section">
	<div class="container">
		<h2>{t('plugins.title')}</h2>
		<p class="lead">{t('plugins.lead')}</p>
		{
			packages.map((pkg) => (
				<div class="pkg">
					<div class="pkg__main">
						<code>{pkg.name}</code>
						<p>{t(`plugin.${shortName(pkg.name)}`)}</p>
					</div>
					<span class="v">v{pkg.version}</span>
				</div>
			))
		}
	</div>
</section>

<footer>
	<div class="container">
		{t('footer.built')} · <a href={repo}>github.com/CartagoGit/mcp-core</a> · BSD-3-Clause
	</div>
</footer>

<Config lang={lang} />
