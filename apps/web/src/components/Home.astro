---
import Marquee from './Marquee.astro';
import Install from './Install.astro';
import Config from './Config.astro';
import { runtimes, clients } from '../data/marquees';
import { useTranslations, type Lang } from '../i18n/ui';
import capabilities from '../data/capabilities.json';

interface Props {
	lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const repo = 'https://github.com/CartagoGit/mcp-vertex';

const NS_LABEL: Record<string, string> = {
	mcpvertex: 'core', proposals: 'proposals', git: 'git', memory: 'memory',
	search: 'search', rules: 'rules', quality: 'quality', docs: 'docs',
	deps: 'deps', notification: 'notification',
};

type ITool = { name: string; namespace: string; description: string };
const tools = capabilities.tools as ITool[];
const groups: Record<string, ITool[]> = {};
for (const tool of tools) (groups[tool.namespace] ??= []).push(tool);
const namespaces = Object.entries(groups).sort((a, b) => a[0].localeCompare(b[0]));

const packages = capabilities.packages as Array<{ name: string; version: string }>;
const shortName = (name: string) => name.replace('@mcp-vertex/', '').replace('@mcp-vertex/', '');
const pluginHref = (slug: string) =>
	lang === 'en' ? `${base}/plugins/${slug}` : `${base}/${lang}/plugins/${slug}`;

// Benchmarks: real payloads measured live (see gen-capabilities.ts) + one
// clearly-labelled illustrative baseline. Bar width is proportional to tokens.
type IBench = { id: string; label: string; bytes: number; tokens: number };
const benches = ((capabilities as { benchmarks?: IBench[] }).benchmarks ?? []) as IBench[];
const benchById = Object.fromEntries(benches.map((b) => [b.id, b]));
const compactTok = benchById.overview_compact?.tokens ?? 0;
const autoTok = benchById.auto_work?.tokens ?? 0;
const coldStartTok = compactTok + autoTok;
const BASELINE_TOK = 4000; // illustrative estimate of orienting by hand
const benchBars = [
	{ name: 'overview (full)', tokens: benchById.overview_full?.tokens ?? 0, kind: '' },
	{ name: 'overview (compact)', tokens: compactTok, kind: '' },
	{ name: 'auto_work', tokens: autoTok, kind: '' },
	{ name: 'compact + auto_work', tokens: coldStartTok, kind: 'is-hl' },
	{ name: t('bench.baseline'), tokens: BASELINE_TOK, kind: 'is-base' },
].filter((b) => b.tokens > 0);
const benchMax = Math.max(1, ...benchBars.map((b) => b.tokens));
---

<SiteNav lang={lang} />

<header class="hero">
	<div class="container">
		<img class="hero__logo" src={`${base}/logo.svg`} width="76" height="76" alt="mcp-vertex" />
		<a class="hero__pkg" href="https://www.npmjs.com/package/@mcp-vertex/core">@mcp-vertex</a>
		<h1>{t('hero.title.a')}<span class="grad">{t('hero.title.b')}</span>{t('hero.title.c')}</h1>
		<p class="tagline">{t('hero.tagline')}</p>
		<div class="ctas">
			<a class="btn btn--primary" href={sectionHref('install')}>{t('hero.ctaInstall')}</a>
			<a class="btn btn--ghost" href={sectionHref('tools')}>{t('hero.ctaTools')}</a>
		</div>
		<p class="runs">{t('hero.runsOn')} · v{capabilities.coreVersion}</p>
	</div>
</header>

<section class="marquees container">
	<Marquee items={runtimes} label={t('marquee.runtimes')} />
	<Marquee items={clients} label={t('marquee.clients')} reverse />
</section>

<ConceptSection lang={lang} />

<section class="section section--featured">
	<div class="container">
		<h2>{t('plugins.title')}</h2>
		<p class="lead">{t('plugins.lead')}</p>
		<div class="featured-grid">
			{featured.map((pkg) => (
				<a class="pkg" href={pluginHref(shortName(pkg.name))}>
					<div class="pkg__main">
						<code>{pkg.name}</code>
						<p>{t(`plugin.${shortName(pkg.name)}`)}</p>
					</div>
					<span class="v">v{pkg.version}</span>
					<span class="pkg__arrow" aria-hidden="true">→</span>
				</a>
			))}
		</div>
		<p class="section__more">
			<a href={sectionHref('plugins')}>{t('plugins.title')} →</a>
			·
			<a href={sectionHref('tools')}>{t('tools.title')} →</a>
		</p>
	</div>
</section>

<SiteFooter lang={lang} />
