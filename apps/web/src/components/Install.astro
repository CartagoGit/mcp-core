---
/**
 * Install.astro — install matrix for `@mcp-vertex/core` (f00048 S2).
 *
 * Three rows of `<Tabs>`, each driving a different layer of the install story:
 *
 *   Row 1 — Package-manager tabs (npm, pnpm, yarn, bun, deno)
 *           → one panel with: init command, verify command, recommendation
 *             badge, and a `Callout` tip.
 *
 *   Row 2 — IDE tabs (VS Code, Cursor, Windsurf, Claude Code, …)
 *           → one panel with: file path, scope, the rendered config JSON
 *             (re-rendered when the PM changes), and a `Callout` explaining
 *             why the snippet has the shape it does.
 *
 *   Row 3 — Preset tabs (minimal, standard, swarm, full)
 *           → one panel with: which plugins ship, size, recommended use,
 *             pulled live from `PRESET_CATALOG`.
 *
 *   Foot — `--check`, `--exclude-plugins=`, and a small FAQ.
 *
 * Each tab change runs a cross-fade via the shared `<Tabs>` primitive. The
 * snippet for the IDE row is pre-computed for every (pm × ide) pair on
 * the server and looked up in the client (no JSON.stringify re-parsed per
 * click).
 */
import { useTranslations, type Lang } from '#I18N/ui';
import {
	PACKAGE,
	ideTargets,
	packageManagers,
	renderConfig,
} from '#DATA/install';
import { brandLogo } from '#LIB/brand-logos';
import { PRESET_CATALOG, resolvePresetMembers } from '@mcp-vertex/core/public';
import Tabs from '#UI/Tabs.astro';
import CodeBlock from '#UI/CodeBlock.astro';
import Callout from '#UI/Callout.astro';
import Stepper from '#UI/Stepper.astro';

interface Props {
	lang: Lang;
	/** Page title. Rendered as the section's <h1>. */
	heading?: string;
}
const { lang, heading: headingProp } = Astro.props;
const t = useTranslations(lang);
const heading = headingProp ?? t.install.title;
const defaultPm = 'bun';
const defaultIde = 'vscode';
const defaultPreset = 'standard';

const PM_HINTS: Record<string, string> = {
	npm: 'Node Package Manager — bundled with Node.js, the universal default.',
	pnpm: 'Fast, disk-efficient package manager with strict dependency resolution.',
	yarn: 'Classic alternative to npm, popular in the JavaScript ecosystem.',
	bun: 'All-in-one JavaScript runtime + package manager. mcp-vertex itself is built with bun.',
	deno: 'Secure-by-default runtime with first-class TypeScript and npm compatibility.',
};

const PM_RECOMMENDED = 'bun';

const IDE_HINTS: Record<string, string> = {
	vscode: 'VS Code with the GitHub Copilot Chat extension.',
	cursor: 'Cursor — VS Code fork with deep AI integration.',
	windsurf: 'Windsurf by Codeium — agentic IDE.',
	'claude-code': 'Anthropic Claude Code CLI.',
	'claude-desktop': 'Anthropic Claude Desktop app.',
	antigravity: 'Google Antigravity (Gemini-backed).',
	zed: 'Zed — high-performance editor.',
};

const scopeFor = (s: string): string =>
	s === 'project'
		? t.install.ideScopeProject
		: s === 'global'
			? t.install.ideScopeGlobal
			: t.install.ideScopeBoth;

// Pre-compute every (pm × ide) snippet so the client only needs a dict
// lookup when a tab changes. Stored as a JSON blob in a data-* attribute
// on the .install root.
const snippets: Record<string, string> = {};
for (const pm of packageManagers) {
	for (const ide of ideTargets) {
		snippets[`${pm.id}|${ide.id}`] = renderConfig(ide, pm);
	}
}

// Pre-compute preset summaries (plugin list, size, recommended use) for
// the third row of tabs. Pulled live from the catalog — no duplication.
const presetEntries = PRESET_CATALOG.map((p) => ({
	id: p.id,
	title: p.title,
	summary: p.summary,
	effective: resolvePresetMembers(p.id),
}));

const pmTabs = packageManagers.map((pm) => ({
	id: pm.id,
	label: pm.label,
	icon: brandLogo(pm.id, 'pm') ?? undefined,
	badge: pm.id === PM_RECOMMENDED ? t.install.pmRecommend : undefined,
}));
const ideTabs = ideTargets.map((ide) => ({
	id: ide.id,
	label: ide.label.split(' · ')[0] ?? ide.label,
}));
const presetTabs = presetEntries.map((p) => ({
	id: p.id,
	label: p.title,
	badge: `${p.effective.length} ${t.install.presetSizeLabel}`,
}));
---

<section id="install" class="section">
	<div class="container">
		<h1>{heading}</h1>
		<p class="lead">{t.install.lead}</p>

		<div
			class="install"
			data-pm={defaultPm}
			data-ide={defaultIde}
			data-snippets={JSON.stringify(snippets)}
		>
			{/* ── Row 1: package manager tabs ─────────────────────────────── */}
			<Tabs
				tabs={pmTabs}
				defaultTab={defaultPm}
				label={t.install.tabsPackageManager}
			>
				{
					packageManagers.map((pm) => (
						<section
							data-tab-panel={pm.id}
							id={`ui-panel-${pm.id}`}
							hidden={pm.id !== defaultPm}
						>
							<Stepper
								steps={[
									`${t.install.pmStep1Title} — run \`${pm.init}\``,
									`${t.install.pmStep2Title} — run \`${pm.run}\``,
								]}
							/>
							<CodeBlock
								code={pm.init}
								lang="bash"
								caption={t.install.oneCmd}
								filename="terminal"
								lang_label={lang}
							/>
							{pm.note && (
								<Callout variant="tip" title={t.install.pmRecommend} lang_label={lang}>
									{pm.note}
								</Callout>
							)}
							{PM_HINTS[pm.id] && (
								<Callout variant="note" lang_label={lang}>
									{PM_HINTS[pm.id]}
								</Callout>
							)}
							<CodeBlock
								code={pm.run}
								lang="bash"
								caption={t.install.verify}
								filename="verify"
								lang_label={lang}
							/>
						</section>
					))
				}
			</Tabs>

			{/* ── Row 2: IDE tabs ─────────────────────────────────────────── */}
			<h2 class="install__h2">{t.install.addto}</h2>
			<Tabs
				tabs={ideTabs}
				defaultTab={defaultIde}
				label={t.install.tabsIde}
				variant="pill"
			>
				{
					ideTargets.map((ide) => (
						<section
							data-tab-panel={ide.id}
							id={`ui-panel-${ide.id}`}
							hidden={ide.id !== defaultIde}
						>
							<header class="install__ide-head">
								<div>
									<span class="install__ide-name">{ide.label}</span>
									{IDE_HINTS[ide.id] && (
										<span class="install__ide-hint">{IDE_HINTS[ide.id]}</span>
									)}
								</div>
								<dl class="install__ide-meta">
									<div>
										<dt>{t.install.ideFileLabel}</dt>
										<dd>
											<code>{ide.file}</code>
										</dd>
									</div>
									<div>
										<dt>{t.install.ideScopeLabel}</dt>
										<dd>{scopeFor(ide.scope)}</dd>
									</div>
								</dl>
							</header>
							<CodeBlock
								code={renderConfig(
									ide,
									packageManagers.find((p) => p.id === defaultPm)!,
								)}
								lang="json"
								filename={(ide.file.split('  ·  ')[0] ?? ide.file)}
								caption={t.install.ideWhyLabel}
								lang_label={lang}
							/>
							<Callout variant="note" lang_label={lang}>
								{t.install.ideWhyBody}
							</Callout>
						</section>
					))
				}
			</Tabs>

			{/* ── Row 3: preset tabs ──────────────────────────────────────── */}
			<h2 class="install__h2">{t.install.presets}</h2>
			<Tabs
				tabs={presetTabs}
				defaultTab={defaultPreset}
				label={t.install.tabsPreset}
				variant="pill"
			>
				{
					presetEntries.map((p) => (
						<section
							data-tab-panel={p.id}
							id={`ui-panel-${p.id}`}
							hidden={p.id !== defaultPreset}
						>
							<header class="install__preset-head">
								<code class="install__preset-cmd">
									{PACKAGE} --preset={p.id}
								</code>
								<p class="install__preset-summary">{p.summary}</p>
							</header>
							<h3 class="install__preset-h3">{t.install.presetPluginsLabel}</h3>
							<ul class="install__preset-plugins">
								{p.effective.map((pluginId) => (
									<li>
										<code>{pluginId}</code>
									</li>
								))}
							</ul>
							<p class="install__preset-foot">
								{t.install.presetFoot}
							</p>
						</section>
					))
				}
			</Tabs>

			{/* ── Foot ───────────────────────────────────────────────────── */}
			<section class="install__faq">
				<h2>{t.install.faqTitle}</h2>
				<details>
					<summary>{t.install.faqQ1}</summary>
					<p>{t.install.faqA1}</p>
				</details>
				<details>
					<summary>{t.install.faqQ2}</summary>
					<p>{t.install.faqA2}</p>
				</details>
				<details>
					<summary>{t.install.faqQ3}</summary>
					<p>{t.install.faqA3}</p>
				</details>
			</section>
		</div>
	</div>
</section>

<script>
	// When the user clicks a PM tab, re-render every IDE panel's
	// config snippet with the new package manager. The pre-computed
	// snippets are baked into `data-snippets` as a JSON map keyed by
	// `${pm}|${ide}`. The Tabs controller (`_tabs-controller.ts`)
	// owns the panel show/hide + animation; we only own the snippet
	// re-render.
	for (const root of document.querySelectorAll<HTMLElement>('.install')) {
		const snippets: Record<string, string> = JSON.parse(
			root.dataset.snippets || '{}',
		);
		const renderIdeCfg = (pm: string) => {
			for (const code of root.querySelectorAll<HTMLElement>(
				'[data-ide-cfg-target]',
			)) {
				const ideId = code.dataset.ideCfgTarget;
				if (!ideId) continue;
				code.textContent = snippets[`${pm}|${ideId}`] ?? '';
			}
		};
		// Re-render when any PM tab is clicked. We rely on the tab's
		// `data-tab-trigger` being one of the PM ids; the rendered
		// triggers live on buttons inside `[data-ui-tabs]`.
		for (const tab of root.querySelectorAll<HTMLButtonElement>(
			'.ui-tabs__tab[data-tab-trigger]',
		)) {
			const id = tab.dataset.tabTrigger;
			if (!id) continue;
			tab.addEventListener('click', () => {
				// First Tabs root is PM; we identify it by checking
				// whether this id is one of the PM ids (passed via the
				// snippets map keys, which include `${pm}|...`).
				const isPm = Object.keys(snippets).some((k) =>
					k.startsWith(`${id}|`),
				);
				if (isPm) {
					root.dataset.pm = id;
					renderIdeCfg(id);
				}
			});
		}
	}
</script>

<style>
	.install {
		display: grid;
		gap: 2rem;
	}
	.install__h2 {
		margin: 0;
		font-size: clamp(1.25rem, 3vw, 1.5rem);
		letter-spacing: -0.01em;
	}
	.install__ide-head {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem 2rem;
		justify-content: space-between;
		align-items: start;
		margin-bottom: 1rem;
	}
	.install__ide-name {
		display: block;
		font-weight: 600;
		font-size: 1.05rem;
	}
	.install__ide-hint {
		color: var(--muted);
		font-size: 0.9rem;
	}
	.install__ide-meta {
		display: grid;
		gap: 0.25rem;
		margin: 0;
		font-size: 0.85rem;
	}
	.install__ide-meta div {
		display: grid;
		grid-template-columns: auto auto;
		gap: 0.5rem;
		align-items: baseline;
	}
	.install__ide-meta dt {
		color: var(--muted);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		font-size: 0.7rem;
	}
	.install__ide-meta dd {
		margin: 0;
		font-family: var(--font-mono, ui-monospace, SFMono-Regular, monospace);
	}
	.install__preset-head {
		display: grid;
		gap: 0.4rem;
		margin-bottom: 1rem;
	}
	.install__preset-cmd {
		font-size: 1.05rem;
		font-weight: 600;
		font-family: var(--font-mono, ui-monospace, SFMono-Regular, monospace);
	}
	.install__preset-summary {
		margin: 0;
		color: var(--muted);
	}
	.install__preset-h3 {
		margin: 0 0 0.5rem;
		font-size: 0.95rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--muted);
	}
	.install__preset-plugins {
		list-style: none;
		padding: 0;
		margin: 0 0 1rem;
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}
	.install__preset-plugins li code {
		padding: 0.2rem 0.55rem;
		border-radius: 999px;
		border: 1px solid var(--line);
		background: color-mix(in srgb, var(--card) 50%, transparent);
		font-size: 0.85rem;
	}
	.install__preset-foot {
		color: var(--muted);
		font-size: 0.9rem;
	}
	.install__faq {
		margin-top: 1rem;
		display: grid;
		gap: 0.5rem;
	}
	.install__faq h2 {
		margin: 0 0 0.5rem;
		font-size: 1.15rem;
	}
	.install__faq details {
		border: 1px solid var(--line);
		border-radius: var(--radius);
		padding: 0.7rem 1rem;
		background: color-mix(in srgb, var(--card) 40%, transparent);
	}
	.install__faq details[open] {
		background: color-mix(in srgb, var(--card) 70%, transparent);
	}
	.install__faq summary {
		cursor: pointer;
		font-weight: 500;
	}
	.install__faq p {
		margin: 0.6rem 0 0;
		color: var(--muted);
	}
</style>