---
/**
 * PageShell.astro — Base + PageHeader composed for translated pages.
 *
 * Every translated page (`/[lang]/<segment>.astro`) wraps its body in
 * `<Base>` + an optional breadcrumb + an `<h1>`. The exact same shell
 * was being copy-pasted 12 times (one per page × once for English at
 * the root) with the same `getStaticPaths`, the same lang guard, the
 * same `<PageHeader>` invocation. PageShell makes that one component:
 *
 *   <PageShell
 *     lang={lang}
 *     title={t.tools.title}
 *     base={base}
 *     crumbs={[{ label: t.nav.tools, href: localePath(lang, 'tools') }]}
 *     metaTitle={`${t.tools.title} — @mcp-vertex/core`}
 *   >
 *     <ToolsSection lang={lang} />
 *   </PageShell>
 *
 * The `metaTitle` is optional; without it the browser tab is just the
 * heading. The slot is mandatory — the shell owns layout chrome, the
 * caller owns the body.
 */
import Base from '#LAYOUTS/Base.astro';
import PageHeader from '#COMPONENTS/PageHeader.astro';
import { defaultLang, type Lang } from '#LIB/page';

interface Crumb {
	readonly label: string;
	readonly href: string;
}

interface Props {
	readonly lang: Lang;
	readonly title: string;
	readonly base?: string;
	readonly crumbs?: ReadonlyArray<Crumb>;
	readonly metaTitle?: string;
	readonly description?: string;
	/** When true, the page renders without the breadcrumb + h1 chrome
	 * (the body is expected to own its own h1, e.g. the home page). */
	readonly bare?: boolean;
}

const {
	lang,
	title,
	base = '',
	crumbs = [],
	metaTitle,
	description,
	bare = false,
} = Astro.props as Props;

const homeHref = lang === defaultLang ? `${base}/` : `${base}/${lang}/`;
---

<Base
	lang={lang}
	title={metaTitle ? `${metaTitle} — @mcp-vertex/core` : `${title} — @mcp-vertex/core`}
	description={description}
>
	{!bare && <PageHeader lang={lang} title={title} crumbs={crumbs} homeHref={homeHref} />}
	<slot />
</Base>
