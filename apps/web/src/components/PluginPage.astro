---
import Config from './Config.astro';
import { useTranslations, type Lang } from '../i18n/ui';
import capabilities from '../data/capabilities.json';

interface Props {
	lang: Lang;
	slug: string;
}
const { lang, slug } = Astro.props;
const t = useTranslations(lang);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const repo = 'https://github.com/CartagoGit/mcp-vertex';
const homeHref = lang === 'en' ? `${base}/` : `${base}/${lang}/`;

// Map a package short-name to its tool namespace (core → mcpcore).
const nsFor = (s: string): string => (s === 'core' ? 'mcpcore' : s);

type ITool = { name: string; namespace: string; description: string; effects?: string[] };
type IPkg = { name: string; version: string };

const pkg = (capabilities.packages as IPkg[]).find(
	(p) => p.name.replace('@mcp-vertex/', '').replace('@mcp-vertex/', '') === slug
);
const ns = nsFor(slug);
const tools = (capabilities.tools as ITool[])
	.filter((tool) => tool.namespace === ns)
	.sort((a, b) => a.name.localeCompare(b.name));

const title = pkg?.name ?? `@mcp-vertex/${slug}`;
const description = t(`plugin.${slug}`);
---

<nav class="nav">
	<div class="container nav__inner">
		<a class="nav__brand" href={homeHref}>
			<img class="nav__logo" src={`${base}/logo.svg`} width="26" height="26" alt="" />
			@mcp-vertex/core
		</a>
		<div class="nav__links">
			<a href={homeHref}>← {t('pluginpage.back')}</a>
			<a href={`${base}/api/`}>API</a>
			<a href={repo}>{t('nav.github')}</a>
			<button class="gear" id="cfg-open" aria-label={t('cfg.title')}>
				<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<circle cx="12" cy="12" r="3"></circle>
					<path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
				</svg>
			</button>
		</div>
	</div>
</nav>

<header class="phead">
	<div class="container">
		<a class="phead__crumb" href={homeHref}>← {t('pluginpage.back')}</a>
		<h1><code>{title}</code></h1>
		<p class="tagline">{description}</p>
		<div class="phead__meta">
			{pkg && <span class="v">v{pkg.version}</span>}
			<span class="phead__count">{tools.length} {t('pluginpage.tools')}</span>
		</div>
	</div>
</header>

<section class="section">
	<div class="container">
		<h2>{t('pluginpage.install')}</h2>
		<pre><code>bun add {title}</code></pre>
		<pre><code>{`{ "args": ["@mcp-vertex/core", "--plugins=${slug}"] }`}</code></pre>

		<h2>{t('pluginpage.tools')}</h2>
		<div class="tools-grid">
			{tools.map((tool) => (
				<div class="tool">
					<div class="tool__head">
						<code>{tool.name}</code>
						{(tool.effects ?? []).map((e) => (
							<span class={`fx fx--${e}`}>{e}</span>
						))}
						{(tool.effects ?? []).length === 0 && <span class="fx fx--read">read-only</span>}
					</div>
					<p>{tool.description}</p>
				</div>
			))}
		</div>
	</div>
</section>

<footer>
	<div class="container">
		{t('footer.built')} · <a href={repo}>github.com/CartagoGit/mcp-vertex</a> · BSD-3-Clause
	</div>
</footer>

<Config lang={lang} />
