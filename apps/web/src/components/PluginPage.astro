---
import { useTranslations, type Lang } from '../i18n/ui';
import capabilities from '../data/capabilities.json';

interface Props {
	lang: Lang;
	slug: string;
}
const { lang, slug } = Astro.props;
const t = useTranslations(lang);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = lang === 'en' ? `${base}/` : `${base}/${lang}/`;
const pluginsHref =
	lang === 'en' ? `${base}/plugins` : `${base}/${lang}/plugins`;

// Map a package short-name to its tool namespace (core → mcp-vertex).
const nsFor = (s: string): string => (s === 'core' ? 'mcp-vertex' : s);

type ITool = {
	name: string;
	namespace: string;
	description: string;
	effects?: string[];
};
type IPkg = { name: string; version: string };

const pkg = (capabilities.packages as IPkg[]).find(
	(p) =>
		p.name.replace('@mcp-vertex/', '').replace('@mcp-vertex/', '') === slug,
);
const ns = nsFor(slug);
const tools = (capabilities.tools as ITool[])
	.filter((tool) => tool.namespace === ns)
	.sort((a, b) => a.name.localeCompare(b.name));

const title = pkg?.name ?? `@mcp-vertex/${slug}`;
const description = t(`plugin.${slug}`);
const repo = 'https://github.com/CartagoGit/mcp-vertex';
---

<section class="subhero">
	<div class="container">
		<nav class="subhero__crumb" aria-label="breadcrumb">
			<a href={homeHref}>{t.nav.concept}</a>
			<span aria-hidden="true">›</span>
			<a href={pluginsHref}>{t.nav.plugins}</a>
			<span aria-hidden="true">›</span>
			<span aria-current="page"><code>{title}</code></span>
		</nav>
		<h1 transition:name="page-title" transition:animate="fade"><code>{title}</code></h1>
		<p class="subhero__lead">{description}</p>
		<div class="subhero__meta">
			{pkg && <span><b>v{pkg.version}</b></span>}
			<span><b>{tools.length}</b>{t.pluginpage.tools}</span>
		</div>
		<div class="subhero__ctas">
			<a class="btn btn--primary" href={`${base}/install`}>{t.pluginpage.install} →</a>
			<a class="btn btn--ghost" href={pluginsHref}>← {t.nav.plugins}</a>
			<a class="btn btn--ghost" href={repo} rel="external">GitHub ↗</a>
		</div>
	</div>
</section>

<section class="section">
	<div class="container">
		<h2>{t.pluginpage.install}</h2>
		<div class="install__cmd-grid">
			<div class="install__cmd-card">
				<span class="install__cmd-label">bun</span>
				<pre><code>bun add {title}</code></pre>
			</div>
			<div class="install__cmd-card">
				<span class="install__cmd-label">npm · pnpm · yarn</span>
				<pre><code>{`{ "args": ["@mcp-vertex/core", "--plugins=${slug}"] }`}</code></pre>
			</div>
		</div>

		<h2>{t.pluginpage.tools}</h2>
		<div class="tools-grid">
			{tools.map((tool) => (
				<div class="tool">
					<div class="tool__head">
						<code>{tool.name}</code>
						{(tool.effects ?? []).map((e) => (
							<span class={`fx fx--${e}`}>{e}</span>
						))}
						{(tool.effects ?? []).length === 0 && <span class="fx fx--read">read-only</span>}
					</div>
					<p>{tool.description}</p>
				</div>
			))}
		</div>
	</div>
</section>