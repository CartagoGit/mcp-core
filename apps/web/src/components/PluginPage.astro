---
import { useTranslations, type Lang } from '../i18n/ui';
import { describeTool } from '../i18n/tools';
import capabilities from '../data/capabilities.json';
import type { ITutorial } from '../../scripts/lib/discover-tutorials';
import PageHeader from './PageHeader.astro';
import Tutorial from './Tutorial.astro';

interface Props {
	lang: Lang;
	slug: string;
}
const { lang, slug } = Astro.props;
const t = useTranslations(lang);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = lang === 'en' ? `${base}/` : `${base}/${lang}/`;
const pluginsHref =
	lang === 'en' ? `${base}/plugins` : `${base}/${lang}/plugins`;

// Map a package short-name to its tool namespace (core → mcp-vertex).
const nsFor = (s: string): string => (s === 'core' ? 'mcp-vertex' : s);

type ITool = {
	name: string;
	namespace: string;
	description: string;
	effects?: string[];
	inputSchema?: {
		fields: ReadonlyArray<{
			name: string;
			type: string;
			required: boolean;
			description?: string;
		}>;
	};
};
type IPkg = {
	name: string;
	version: string;
	configExample?: {
		summary: string;
		options: Record<string, unknown>;
	};
};

const pkg = (capabilities.packages as IPkg[]).find(
	(p) =>
		p.name.replace('@mcp-vertex/', '').replace('@mcp-vertex/', '') === slug,
);
const slugOf = (n: string): string => n.replace('@mcp-vertex/', '');
// Filter tutorials for this plugin; empty when none exists.
const pluginTutorials = (
	(capabilities as { tutorials?: ITutorial[] }).tutorials ?? []
).filter((t) => slugOf(t.plugin) === slug);
const ns = nsFor(slug);
const tools = (capabilities.tools as ITool[])
	.filter((tool) => tool.namespace === ns)
	.sort((a, b) => a.name.localeCompare(b.name));
// Localized description with graceful English fallback.
const toolDesc = (tool: ITool) =>
	describeTool(tool.name, lang) ?? tool.description;

const title = pkg?.name ?? `@mcp-vertex/${slug}`;
const description = t(`plugin.${slug}`);
const repo = 'https://github.com/CartagoGit/mcp-vertex';
---

<PageHeader
	lang={lang}
	title={title}
	crumbs={[
		{ label: t.nav.plugins, href: pluginsHref },
	]}
/>
<section class="section">
	<div class="container">
		<h2>{t.pluginpage.install}</h2>
		<div class="install__cmd-grid">
			<div class="install__cmd-card">
				<span class="install__cmd-label">bun</span>
				<pre><code>bun add {title}</code></pre>
			</div>
			<div class="install__cmd-card">
				<span class="install__cmd-label">npm · pnpm · yarn</span>
				<pre><code>{`{ "args": ["@mcp-vertex/core", "--plugins=${slug}"] }`}</code></pre>
			</div>
		</div>

		<h2>{t.pluginpage.tools}</h2>
		<div class="tools-grid">
			{tools.map((tool) => (
				<div class="tool card">
					<div class="tool__head">
						<code>{tool.name}</code>
						{(tool.effects ?? []).map((e) => (
							<span class={`fx fx--${e}`}>{e}</span>
						))}
						{(tool.effects ?? []).length === 0 && <span class="fx fx--read">read-only</span>}
					</div>
					<p>{toolDesc(tool)}</p>
					{(tool.inputSchema?.fields.length ?? 0) > 0 && (
						<table class="args">
							<caption>{tool.name} arguments</caption>
							<thead>
								<tr>
									<th scope="col">Argument</th>
									<th scope="col">Type</th>
									<th scope="col">Required</th>
									<th scope="col">Description</th>
								</tr>
							</thead>
							<tbody>
								{(tool.inputSchema?.fields ?? []).map((field) => (
									<tr>
										<td><code>{field.name}</code></td>
										<td><code>{field.type}</code></td>
										<td>{field.required ? 'yes' : 'no'}</td>
										<td>{field.description ?? '—'}</td>
									</tr>
								))}
							</tbody>
						</table>
					)}
				</div>
			))}
		</div>

		{pkg?.configExample && (
			<section class="config">
				<h2>{t.pluginpage.configuration ?? 'Configuration'}</h2>
				<p>{pkg.configExample.summary}</p>
				<div class="config__snippet">
					<button
						type="button"
						class="config__copy"
						data-copy-target={`cfg-${slug}`}
					>
						Copy
					</button>
					<pre id={`cfg-${slug}`}><code>{
						// The outer object mirrors the user's mcp-vertex.config.json
						// so they can paste the whole block. The plugin key is the
						// package short-name; `options` is what the plugin sees as
						// `ctx.options` at registration time.
						JSON.stringify(
							{
								plugins: {
									[slug]: {
										options: pkg.configExample.options,
									},
								},
							},
							null,
							2,
						)

		<PluginTutorials
			tutorials={pluginTutorials}
			plugin={slug}
			lang={langCode}
		/>
					}</code></pre>
				</div>
			</section>
		)}
	</div>
</section>

{pkg?.configExample && (
	<script is:inline>
		// Minimal copy-to-clipboard handler for the config snippet. Inline so
		// it works without a JS framework. Runs once per page; uses event
		// delegation on the document so re-renders don't re-bind.
		document.addEventListener('click', (event) => {
			const target = event.target;
			if (!(target instanceof HTMLElement)) return;
			const btn = target.closest('button.config__copy');
			if (!btn) return;
			const id = btn.getAttribute('data-copy-target');
			if (!id) return;
			const pre = document.getElementById(id);
			if (!pre) return;
			const text = pre.innerText;
			const finish = (ok: boolean): void => {
				btn.textContent = ok ? 'Copied!' : 'Press Ctrl+C';
				setTimeout(() => {
					btn.textContent = 'Copy';
				}, 2000);
			};
			if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
				navigator.clipboard.writeText(text).then(
					() => finish(true),
					() => finish(false),
				);
			} else {
				// Legacy fallback for older browsers / non-HTTPS.
				const range = document.createRange();
				range.selectNodeContents(pre);
				const selection = window.getSelection();
				if (selection) {
					selection.removeAllRanges();
					selection.addRange(range);
					finish(true);
				} else {
					finish(false);
				}
			}
		});
	</script>
)}