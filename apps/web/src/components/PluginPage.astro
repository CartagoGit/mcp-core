---
import Config from './Config.astro';
import SiteNav from './SiteNav.astro';
import SiteFooter from './SiteFooter.astro';
import { useTranslations, type Lang } from '../i18n/ui';
import capabilities from '../data/capabilities.json';

interface Props {
	lang: Lang;
	slug: string;
}
const { lang, slug } = Astro.props;
const t = useTranslations(lang);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = lang === 'en' ? `${base}/` : `${base}/${lang}/`;

// Map a package short-name to its tool namespace (core → mcpvertex).
const nsFor = (s: string): string => (s === 'core' ? 'mcpvertex' : s);

type ITool = { name: string; namespace: string; description: string; effects?: string[] };
type IPkg = { name: string; version: string };

const pkg = (capabilities.packages as IPkg[]).find(
	(p) => p.name.replace('@mcp-vertex/', '').replace('@mcp-vertex/', '') === slug
);
const ns = nsFor(slug);
const tools = (capabilities.tools as ITool[])
	.filter((tool) => tool.namespace === ns)
	.sort((a, b) => a.name.localeCompare(b.name));

const title = pkg?.name ?? `@mcp-vertex/${slug}`;
const description = t(`plugin.${slug}`);
---

<SiteNav lang={lang} />

<header class="phead">
	<div class="container">
		<a class="phead__crumb" href={homeHref}>← {t('pluginpage.back')}</a>
		<h1><code>{title}</code></h1>
		<p class="tagline">{description}</p>
		<div class="phead__meta">
			{pkg && <span class="v">v{pkg.version}</span>}
			<span class="phead__count">{tools.length} {t('pluginpage.tools')}</span>
		</div>
	</div>
</header>

<section class="section">
	<div class="container">
		<h2>{t('pluginpage.install')}</h2>
		<pre><code>bun add {title}</code></pre>
		<pre><code>{`{ "args": ["@mcp-vertex/core", "--plugins=${slug}"] }`}</code></pre>

		<h2>{t('pluginpage.tools')}</h2>
		<div class="tools-grid">
			{tools.map((tool) => (
				<div class="tool">
					<div class="tool__head">
						<code>{tool.name}</code>
						{(tool.effects ?? []).map((e) => (
							<span class={`fx fx--${e}`}>{e}</span>
						))}
						{(tool.effects ?? []).length === 0 && <span class="fx fx--read">read-only</span>}
					</div>
					<p>{tool.description}</p>
				</div>
			))}
		</div>
	</div>
</section>

<SiteFooter lang={lang} />

<Config lang={lang} />
