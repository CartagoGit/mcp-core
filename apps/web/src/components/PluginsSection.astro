---
import { useTranslations, type Lang } from '../i18n/ui';
import capabilities from '../data/capabilities.json';

interface Props {
	lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const packages = capabilities.packages as Array<{
	name: string;
	version: string;
}>;
const shortName = (name: string) =>
	name.replace('@mcp-vertex/', '').replace('@mcp-vertex/', '');
const pluginHref = (slug: string) =>
	lang === 'en'
		? `${base}/plugins/${slug}`
		: `${base}/${lang}/plugins/${slug}`;
---

<section id="plugins" class="section">
	<div class="container">
		<h2>{t.plugins.title}</h2>
		<p class="lead">{t.plugins.lead}</p>
		{
			packages.map((pkg) => (
				<a class="pkg" href={pluginHref(shortName(pkg.name))}>
					<div class="pkg__main">
						<code>{pkg.name}</code>
						<p>{t(`plugin.${shortName(pkg.name)}`)}</p>
					</div>
					<span class="v">v{pkg.version}</span>
					<span class="pkg__arrow" aria-hidden="true">→</span>
				</a>
			))
		}
	</div>
</section>
