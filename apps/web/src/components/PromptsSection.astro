---
/**
 * PromptsSection.astro — body of the `/prompts` index.
 *
 * Thin wrapper around `CapabilityGrid` (the shared "list of capability
 * cards grouped by namespace" primitive). Prompts are detail-less
 * cards (no per-prompt page in this build) so they render as `<div>`
 * inside the grid. Argument descriptions come from the catalogue.
 */
import { type Lang, useTranslations } from '#I18N/ui';
import { describePrompt, describePromptArg } from '#I18N/tools';
import capabilities from '#MANIFESTS/capabilities.json';
import CapabilityGrid from '#COMPONENTS/CapabilityGrid.astro';

interface Props {
	readonly lang: Lang;
	readonly heading: string;
}
const { lang, heading: _heading } = Astro.props;
const t = useTranslations(lang);

type IPrompt = {
	name: string;
	description: string;
	namespace: string;
	arguments?: Array<{
		name: string;
		description: string;
		required?: boolean;
	}>;
};
const prompts = (capabilities.prompts ?? []) as IPrompt[];
---

<section id="prompts" class="section">
	<div class="container">
		<p class="lead">{t.prompts.lead}</p>
		<div class="stat-row">
			<div class="stat">
				<b>{capabilities.counts.prompts ?? prompts.length}</b>
				<span>{t.prompts.count}</span>
			</div>
		</div>
		<CapabilityGrid
			kind="prompt"
			items={prompts}
			labels={{ stat: t.prompts.count, empty: t.prompts.lead }}
			describe={(p) => {
				const it = p as IPrompt;
				return describePrompt(it.name, lang) ?? it.description;
			}}
			argDescription={(p, argName, fallback) =>
				describePromptArg((p as IPrompt).name, argName, lang) ?? fallback}
			promptArgLabel={t.prompts.arg}
			sectionId="prompts"
		/>
	</div>
</section>