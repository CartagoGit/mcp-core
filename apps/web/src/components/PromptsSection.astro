---
import { useTranslations, type Lang } from '#I18N/ui';
import { describePrompt, describePromptArg } from '#I18N/tools';
import capabilities from '#MANIFESTS/capabilities.json';

interface Props {
	lang: Lang;
	/** Page title. Rendered as the section's <h1> (l122 S3). */
	heading?: string;
}
const { lang, heading: headingProp } = Astro.props;
const t = useTranslations(lang);
const heading = headingProp ?? t.prompts.title;

type IPrompt = {
	name: string;
	description: string;
	namespace: string;
	arguments?: Array<{
		name: string;
		description: string;
		required?: boolean;
	}>;
};

const prompts = (capabilities.prompts ?? []) as IPrompt[];
const groups: Record<string, IPrompt[]> = {};
for (const p of prompts) {
	if (!groups[p.namespace]) groups[p.namespace] = [];
	groups[p.namespace].push(p);
}
const namespaces = Object.entries(groups).sort((a, b) =>
	a[0].localeCompare(b[0]),
);
const desc = (p: IPrompt) => describePrompt(p.name, lang) ?? p.description;
const argDesc = (p: IPrompt, argName: string, fallback: string) =>
	describePromptArg(p.name, argName, lang) ?? fallback;
---

<section id="prompts" class="section">
	<div class="container">
		<h1>{heading}</h1>
		<p class="lead">{t.prompts.lead}</p>
		<div class="stat-row">
			<div class="stat"><b>{capabilities.counts.prompts ?? prompts.length}</b><span>{t.prompts.count}</span></div>
		</div>
		{
			namespaces.length === 0 ? (
				<p class="lead">{t.prompts.lead}</p>
			) : (
				namespaces.map(([ns, list]) => (
					<div class="ns">
						<div class="ns__head"><h3>{ns}</h3><span class="ns__count">{list.length}</span></div>
						<div class="prompts-grid">
							{list.map((prompt) => (
								<div class="prompt card">
									<div class="tool__head">
										<code>{prompt.name}</code>
									</div>
									<p>{desc(prompt)}</p>
									{prompt.arguments && prompt.arguments.length > 0 && (
										<details class="prompt__args">
											<summary>{t.prompts.arg} ({prompt.arguments.length})</summary>
											<ul>
												{prompt.arguments.map((a) => (
													<li><code>{a.name}</code>{a.required && <span class="prompt__req">*</span>} — {argDesc(prompt, a.name, a.description)}</li>
												))}
											</ul>
										</details>
									)}
								</div>
							))}
						</div>
					</div>
				))
			)
		}
	</div>
</section>