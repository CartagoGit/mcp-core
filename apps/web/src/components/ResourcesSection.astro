---
import { useTranslations, type Lang } from '#I18N/ui';
import { describeResource, describeResourceName } from '#I18N/tools';
import capabilities from '#MANIFESTS/capabilities.json';

interface Props {
	lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

type IResource = {
	uri: string;
	name: string;
	description: string;
	namespace: string;
	mimeType?: string;
};

const resources = (capabilities.resources ?? []) as IResource[];
const groups: Record<string, IResource[]> = {};
for (const r of resources) {
	if (!groups[r.namespace]) groups[r.namespace] = [];
	groups[r.namespace].push(r);
}
const namespaces = Object.entries(groups).sort((a, b) =>
	a[0].localeCompare(b[0]),
);
const desc = (r: IResource) => describeResource(r.uri, lang) ?? r.description;
const name = (r: IResource) =>
	describeResourceName(r.uri, lang) ?? r.name ?? r.uri;
---

<section id="resources" class="section">
	<div class="container">
		<h2>{t.resources.title}</h2>
		<p class="lead">{t.resources.lead}</p>
		<div class="stat-row">
			<div class="stat"><b>{capabilities.counts.resources ?? resources.length}</b><span>{t.resources.count}</span></div>
		</div>
		{
			namespaces.length === 0 ? (
				<p class="lead">{t.resources.lead}</p>
			) : (
				namespaces.map(([ns, list]) => (
					<div class="ns">
						<div class="ns__head"><h3>{ns}</h3><span class="ns__count">{list.length}</span></div>
						<table class="resources-table">
							<thead>
								<tr>
									<th>{t.resources.uri}</th>
									<th>{t.resources.mime}</th>
									<th>{t.resources.title}</th>
								</tr>
							</thead>
							<tbody>
								{list.map((r) => (
									<tr>
										<td><code>{r.uri}</code></td>
										<td>{r.mimeType ?? '—'}</td>
										<td>
											<strong>{name(r)}</strong>
											<p class="muted">{desc(r)}</p>
										</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				))
			)
		}
	</div>
</section>