---
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
	lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const repo = 'https://github.com/CartagoGit/mcp-vertex';
---

<footer transition:persist transition:name="site-footer">
	<div class="container">
		{t('footer.built')} · <a href={repo}>github.com/CartagoGit/mcp-vertex</a> · BSD-3-Clause
	</div>
</footer>
