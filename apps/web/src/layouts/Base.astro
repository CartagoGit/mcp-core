---
import SiteNav from '#COMPONENTS/SiteNav.astro';
import SiteFooter from '#COMPONENTS/SiteFooter.astro';
import Config from '#COMPONENTS/Config.astro';
import Search from '#COMPONENTS/Search.astro';
import '../styles/styles.scss';
import { ClientRouter } from 'astro:transitions';
import { rtlLangs, type Lang } from '#I18N/ui';

interface Props {
	lang: Lang;
	title?: string;
	description?: string;
}

const {
	lang,
	title = '@mcp-vertex/core — agnostic MCP server core',
	description = 'A project-agnostic Model Context Protocol server core + CLI plugin loader. Runs under Node, Deno and bun.',
} = Astro.props;
const dir = rtlLangs.includes(lang) ? 'rtl' : 'ltr';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang={lang} dir={dir}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={`${base}/logo.svg`} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta name="theme-color" content="#0d1117" />
		{/* Enable the View Transitions API. The header, footer and settings
		    modal are mounted once in this layout and persist across navigations
		    via `transition:persist`, so they never remount and never "jump". */}
		<ClientRouter />
		<script>
			// Apply the saved theme/motion before paint (no flash of default
			// theme), and re-apply it after every View Transition. The original
			// `is:inline` shim only runs once because Astro cannot re-execute
			// the same inline bytes after a swap; promoting it to a real
			// `<script>` lets us register an `astro:after-swap` listener that
			// re-runs the same restore on every navigation.
			const KEY_THEME = 'mcpvertex-theme';
			const KEY_MOTION = 'mcpvertex-motion';
			const applyTheme = () => {
				try {
					const t = localStorage.getItem(KEY_THEME);
					if (t) document.documentElement.dataset.theme = t;
					const m = localStorage.getItem(KEY_MOTION);
					if (m === 'off') document.documentElement.dataset.motion = 'off';
					else document.documentElement.removeAttribute('data-motion');
				} catch {}
			};
			applyTheme();
			document.addEventListener('astro:after-swap', applyTheme);

			// x124 S2 — Re-bind nav and footer hrefs after every view
			// transition. The chrome is mounted once with
			// `transition:persist`, so the SSR-rendered hrefs (in the
			// original language) would otherwise stick around after a
			// language change. We read the active locale from
			// `<html lang>` and rewrite the href of every in-page link
			// inside the nav and the footer so the user can keep
			// navigating in the new locale from any persisted chrome
			// surface.
			const LOCALE_CODES = new Set([
				'en', 'es', 'fr', 'de', 'pt', 'it', 'zh', 'hi', 'ar', 'ja', 'vi', 'th',
			]);
			const stripLocale = (path) => {
				const segs = path.split('/').filter(Boolean);
				if (segs[0] && LOCALE_CODES.has(segs[0]) && segs[0] !== 'en') {
					return '/' + segs.slice(1).join('/');
				}
				return path || '/';
			};
			const rewireHrefs = () => {
				const lang = document.documentElement.lang || 'en';
				const relative = stripLocale(location.pathname);
				const targets = document.querySelectorAll(
					'.nav__links a, .sitefoot a[href]',
				);
				for (const a of targets) {
					const href = a.getAttribute('href') || '';
					// Skip external / mailto / anchor / absolute URLs — only
					// rewrite in-site relative links.
					if (
						!/^\/(?!\/)/.test(href) ||
						href.startsWith('//') ||
						href.startsWith('/api/') ||
						href.startsWith('/flags/') ||
						href.startsWith('/logos/')
					) {
						continue;
					}
					const cleanHref = href.split('#')[0] || '/';
					// Extract the segment path (strip the locale prefix if
					// present, then re-add the new locale's prefix).
					const targetRel = stripLocale(cleanHref);
					const next = lang === 'en' ? targetRel : `/${lang}${targetRel === '/' ? '/' : targetRel}`;
					if (a.getAttribute('href') !== next) a.setAttribute('href', next);
				}
			};
			rewireHrefs();
			document.addEventListener('astro:after-swap', rewireHrefs);
		</script>
	</head>
	<body>
		<SiteNav lang={lang} />
		<main id="main" transition:animate="fade"><slot /></main>
		<SiteFooter lang={lang} />
		<Config lang={lang} />
		<Search lang={lang} />
	</body>
</html>
