---
import SiteNav from '#COMPONENTS/SiteNav.astro';
import SiteFooter from '#COMPONENTS/SiteFooter.astro';
import Config from '#COMPONENTS/Config.astro';
import '../styles/styles.scss';
import { ClientRouter } from 'astro:transitions';
import { rtlLangs, type Lang } from '#I18N/ui';

interface Props {
	lang: Lang;
	title?: string;
	description?: string;
}

const {
	lang,
	title = '@mcp-vertex/core — agnostic MCP server core',
	description = 'A project-agnostic Model Context Protocol server core + CLI plugin loader. Runs under Node, Deno and bun.',
} = Astro.props;
const dir = rtlLangs.includes(lang) ? 'rtl' : 'ltr';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang={lang} dir={dir}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={`${base}/logo.svg`} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta name="theme-color" content="#0d1117" />
		{/* Enable the View Transitions API. The header, footer and settings
		    modal are mounted once in this layout and persist across navigations
		    via `transition:persist`, so they never remount and never "jump". */}
		<ClientRouter />
		<script is:inline>
			// Apply the saved theme/motion before paint (no flash of default theme).
			// This script runs again after every View Transition via
			// `astro:after-swap`, so the data attributes survive navigation.
			(() => {
				try {
					const t = localStorage.getItem('mcpvertex-theme');
					if (t) document.documentElement.dataset.theme = t;
					if (localStorage.getItem('mcpvertex-motion') === 'off')
						document.documentElement.dataset.motion = 'off';
				} catch {}
			})();
		</script>
	</head>
	<body>
		<SiteNav lang={lang} />
		<main id="main" transition:animate="fade"><slot /></main>
		<SiteFooter lang={lang} />
		<Config lang={lang} />
	</body>
</html>
