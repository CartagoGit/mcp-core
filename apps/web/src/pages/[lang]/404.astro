---
import Base from '../../layouts/Base.astro';
import NotFound from '../../components/NotFound.astro';
import { languages, useTranslations, type Lang } from '../../i18n/ui';

/** Localised 404: pre-render one page per non-English locale at /<lang>/404.
    The English copy lives in the root /404.astro so the project-site URL
    stays clean (no /en/ prefix). */
export function getStaticPaths() {
	return languages
		.filter((l) => l.code !== 'en')
		.map((l) => ({ params: { lang: l.code } }));
}

const { lang } = Astro.params;
// Runtime guard: never render lang="undefined" (was the root cause of
// "switching language only translates the home page" — Astro fell back
// to English silently). Same pattern as index.astro, guide.astro and
// plugins/[plugin].astro.
const langCode: Lang = (
	lang && languages.some((l) => l.code === lang) ? lang : 'en'
) as Lang;
const t = useTranslations(langCode);
---

<Base
	lang={langCode}
	title={`404 · ${t.notFound.title} — @mcp-vertex/core`}
	description={t.notFound.lead}
>
	<NotFound lang={langCode} />
</Base>
