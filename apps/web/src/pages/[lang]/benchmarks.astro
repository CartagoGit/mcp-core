---
import Base from '../../layouts/Base.astro';
import BenchmarksSection from '../../components/BenchmarksSection.astro';
import { languages, useTranslations, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
	return languages
		.filter((l) => l.code !== 'en')
		.map((l) => ({ params: { lang: l.code } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as Lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = `${base}/${lang}/`;
---

<Base lang={lang as Lang} title={`${t.bench.title} — @mcp-vertex/core`}>
	<section class="subhero">
		<div class="container">
			<nav class="subhero__crumb" aria-label="breadcrumb">
				<a href={homeHref}>{t.nav.concept}</a>
				<span aria-hidden="true">›</span>
				<span aria-current="page">{t.bench.title}</span>
			</nav>
			<h1 transition:name="page-title" transition:animate="fade">{t.bench.title}</h1>
			<p class="subhero__lead">{t.bench.lead}</p>
			<div class="subhero__ctas">
				<a class="btn btn--ghost" href={`${base}/${lang}/install`}>{t.nav.install} →</a>
				<a class="btn btn--ghost" href={`${base}/${lang}/tools`}>{t.nav.tools} →</a>
			</div>
		</div>
	</section>
	<BenchmarksSection lang={lang as Lang} />
</Base>