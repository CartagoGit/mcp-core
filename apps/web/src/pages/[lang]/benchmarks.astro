---
import BenchmarksSection from '#COMPONENTS/BenchmarksSection.astro';
import Base from '#LAYOUTS/Base.astro';
import { languages, useTranslations, type Lang } from '#I18N/ui';

export function getStaticPaths() {
	return languages
		.filter((l) => l.code !== 'en')
		.map((l) => ({ params: { lang: l.code } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as Lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = `${base}/${lang}/`;
---

<Base lang={lang as Lang} title={`${t.bench.title} — @mcp-vertex/core`}>
	<BenchmarksSection lang={lang as Lang} heading={t.bench.title} />
</Base>
