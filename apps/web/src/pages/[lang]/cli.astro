---
/**
 * pages/[lang]/cli.astro — localized routes for the CLI guide (f00053 S5).
 *
 * All non-English locales get their own /<lang>/cli. The English copy
 * lives in the root /cli.astro. The guide body is data-driven (English
 * content from cli-guide), with a pending-translation notice like the
 * sibling /guide page.
 */
import Base from '#LAYOUTS/Base.astro';
import PageHeader from '#COMPONENTS/PageHeader.astro';
import { languages, type Lang } from '#I18N/ui';
import { CLI_GUIDE } from '#DATA/cli-guide';

export function getStaticPaths() {
	return languages
		.filter((l) => l.code !== 'en')
		.map((l) => ({ params: { lang: l.code } }));
}

const { lang } = Astro.params;
const langCode: Lang = (
	lang && languages.some((l) => l.code === lang) ? lang : 'en'
) as Lang;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = `${base}/${langCode}/`;
const g = CLI_GUIDE;
---

<Base
	lang={langCode}
	title="CLI guide — @mcp-vertex/core"
	description="How to drive the mcpv / @mcp-vertex/core CLI: global flags, per-plugin command groups, and common workflows."
>
	<PageHeader lang={langCode} title="CLI guide" />
	<section class="section">
		<div class="container">
			<p class="guide__notice">
				⚠ This CLI guide is in <strong>English</strong>. Translations for {langCode}
				are pending — see <a href={homeHref}>the home page</a> for what's
				translated so far.
			</p>

			<h2 id="flags">Global flags</h2>
			<table class="args">
				<thead>
					<tr>
						<th scope="col">Flag</th>
						<th scope="col">What it does</th>
					</tr>
				</thead>
				<tbody>
					{
						g.globalFlags.map((flag) => (
							<tr>
								<td><code>{flag.flag}</code></td>
								<td>
									{flag.summary}
									{flag.example && (
										<div>
											<code>{flag.example}</code>
										</div>
									)}
								</td>
							</tr>
						))
					}
				</tbody>
			</table>

			<h2 id="commands">Command groups</h2>
			<div class="cli-groups">
				{
					g.commandGroups.map((group) => (
						<div class="cli-group card">
							<code class="cli-group__id">{group.id}</code>
							<strong>{group.title}</strong>
							<p>{group.summary}</p>
						</div>
					))
				}
			</div>

			<h2 id="workflows">Common workflows</h2>
			{
				g.workflows.map((flow) => (
					<section class="cli-workflow">
						<h3>{flow.title}</h3>
						<ol>
							{flow.steps.map((step) => (
								<li>{step}</li>
							))}
						</ol>
					</section>
				))
			}
		</div>
	</section>
</Base>

<style>
	.cli-groups {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
		gap: 1rem;
		margin: 1rem 0 2rem;
	}
	.cli-group {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding: 1rem 1.1rem;
	}
	.cli-group__id {
		font-size: 0.78rem;
		color: var(--accent);
	}
	.cli-group p {
		margin: 0;
		color: var(--muted);
		font-size: 0.9rem;
		line-height: 1.5;
	}
	.cli-workflow {
		padding: 0.5rem 0 1rem;
	}
	.cli-workflow ol {
		line-height: 1.6;
	}
</style>
