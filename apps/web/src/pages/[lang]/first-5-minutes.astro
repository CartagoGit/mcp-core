---
/**
 * pages/[lang]/first-5-minutes.astro — translated onboarding.
 * See `tools.astro` for the shell recipe.
 */
import FirstFiveMinutesSection from '#COMPONENTS/FirstFiveMinutesSection.astro';
import PageShell from '#COMPONENTS/PageShell.astro';
import { langStaticPaths, resolveLang, localePath } from '#LIB/page';
import { useTranslations } from '#I18N/ui';

export const getStaticPaths = langStaticPaths;

const lang = resolveLang(Astro.params.lang);
const t = useTranslations(lang);
---

<PageShell
	lang={lang}
	title={t.firstFiveMinutes.title}
	base={import.meta.env.BASE_URL.replace(/\/$/, '')}
	crumbs={[{ label: t.nav.firstFiveMinutes, href: localePath(lang, 'first-5-minutes') }]}
>
	<FirstFiveMinutesSection lang={lang} />
</PageShell>
