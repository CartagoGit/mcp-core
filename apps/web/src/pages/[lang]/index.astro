---
import { languages } from '../../i18n/ui';

/** All non-English locales get their own /<lang>/. The English copy
 * lives in the root /index.astro (project-site URL stays clean). */
export function getStaticPaths() {
	return languages
		.filter((l) => l.code !== 'en')
		.map((l) => ({ params: { lang: l.code } }));
}

// biome-ignore lint/correctness/noUnusedVariables: consumed by the template below
const { lang } = Astro.params;
---

<Base lang={lang as Lang}>
	<Home lang={lang as Lang} />
</Base>