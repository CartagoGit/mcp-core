---
import { languages, useTranslations, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
	return languages
		.filter((l) => l.code !== 'en')
		.map((l) => ({ params: { lang: l.code } }));
}

const { lang } = Astro.params;
const _t = useTranslations(lang as Lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const _homeHref = `${base}/${lang}/`;
---

<Base lang={lang as Lang} title={`${t.install.title} — @mcp-vertex/core`}>
	<section class="subhero">
		<div class="container">
			<nav class="subhero__crumb" aria-label="breadcrumb">
				<a href={homeHref}>{t.nav.concept}</a>
				<span aria-hidden="true">›</span>
				<span aria-current="page">{t.install.title}</span>
			</nav>
			<h1 transition:name="page-title" transition:animate="fade">{t.install.title}</h1>
			<p class="subhero__lead">{t.install.lead}</p>
			<div class="subhero__ctas">
				<a class="btn btn--primary" href={`${base}/${lang}/tools`}>{t.nav.tools} →</a>
				<a class="btn btn--ghost" href={`${base}/${lang}/plugins`}>{t.nav.plugins} →</a>
			</div>
		</div>
	</section>
	<Install lang={lang as Lang} />
</Base>