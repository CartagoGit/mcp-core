---
/**
 * `/[lang]/install` — localized install page. See
 * `pages/[lang]/tools.astro` for the recipe.
 */
import Install from '#COMPONENTS/Install.astro';
import PageShell from '#COMPONENTS/PageShell.astro';
import { langStaticPaths, resolveLang, localePath } from '#LIB/page';
import { useTranslations } from '#I18N/ui';

export const getStaticPaths = langStaticPaths;

const lang = resolveLang(Astro.params.lang);
const t = useTranslations(lang);
---

<PageShell
	lang={lang}
	title={t.install.title}
	base={import.meta.env.BASE_URL.replace(/\/$/, '')}
	crumbs={[{ label: t.nav.install, href: localePath(lang, 'install') }]}
>
	<Install lang={lang} />
</PageShell>
