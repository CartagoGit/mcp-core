---
import Install from '../../components/Install.astro';
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import { languages, useTranslations, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
	return languages
		.filter((l) => l.code !== 'en')
		.map((l) => ({ params: { lang: l.code } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as Lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = `${base}/${lang}/`;
---

<Base lang={lang as Lang} title={`${t.install.title} — @mcp-vertex/core`}>
	<PageHeader lang={lang as Lang} title={t.install.title} />
	<Install lang={lang as Lang} />
</Base>
