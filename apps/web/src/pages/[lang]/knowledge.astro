---
/**
 * pages/[lang]/knowledge.astro — translated `/<lang>/knowledge` index.
 * See `tools.astro` for the shell recipe.
 */
import KnowledgeSection from '#COMPONENTS/KnowledgeSection.astro';
import PageShell from '#COMPONENTS/PageShell.astro';
import { langStaticPaths, resolveLang, localePath } from '#LIB/page';
import { useTranslations } from '#I18N/ui';

export const getStaticPaths = langStaticPaths;

const lang = resolveLang(Astro.params.lang);
const t = useTranslations(lang);
---

<PageShell
	lang={lang}
	title={t.knowledge.title}
	base={import.meta.env.BASE_URL.replace(/\/$/, '')}
	crumbs={[{ label: t.nav.knowledge, href: localePath(lang, 'knowledge') }]}
>
	<KnowledgeSection lang={lang} heading={t.knowledge.title} />
</PageShell>
