---
import Base from '../../../layouts/Base.astro';
import PluginPage from '../../../components/PluginPage.astro';
import capabilities from '../../../data/capabilities.json';
import { languages, type Lang } from '../../../i18n/ui';

export function getStaticPaths() {
	const slugOf = (name: string) =>
		name.replace('@mcp-vertex/', '').replace('@mcp-vertex/', '');
	const slugs = (capabilities.packages as Array<{ name: string }>).map((p) => slugOf(p.name));
	const langs = languages.map((l) => l.code).filter((c) => c !== 'en');
	return langs.flatMap((lang) => slugs.map((plugin) => ({ params: { lang, plugin } })));
}

const { lang, plugin } = Astro.params;
---

<Base lang={lang as Lang}>
	<PluginPage lang={lang as Lang} slug={plugin!} />
</Base>
