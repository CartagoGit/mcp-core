---
/**
 * `/[lang]/plugins` — localized plugins index. See
 * `pages/[lang]/tools.astro` for the recipe.
 */
import PluginsSection from '#COMPONENTS/PluginsSection.astro';
import PageShell from '#COMPONENTS/PageShell.astro';
import { langStaticPaths, resolveLang, localePath } from '#LIB/page';
import { useTranslations } from '#I18N/ui';

export const getStaticPaths = langStaticPaths;

const lang = resolveLang(Astro.params.lang);
const t = useTranslations(lang);
---

<PageShell
	lang={lang}
	title={t.plugins.title}
	base={import.meta.env.BASE_URL.replace(/\/$/, '')}
	crumbs={[{ label: t.nav.plugins, href: localePath(lang, 'plugins') }]}
>
	<PluginsSection lang={lang} heading={t.plugins.title} />
</PageShell>
