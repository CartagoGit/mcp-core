---
import PluginsSection from '#COMPONENTS/PluginsSection.astro';
import Base from '#LAYOUTS/Base.astro';
import { languages, useTranslations, type Lang } from '#I18N/ui';
import capabilities from '#MANIFESTS/capabilities.json';

export function getStaticPaths() {
	return languages
		.filter((l) => l.code !== 'en')
		.map((l) => ({ params: { lang: l.code } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as Lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = `${base}/${lang}/`;
const count = capabilities.counts.packages;
---

<Base lang={lang as Lang} title={`${t.plugins.title} — @mcp-vertex/core`}>
	<PluginsSection lang={lang as Lang} heading={t.plugins.title} />
</Base>
