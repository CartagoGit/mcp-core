---
import { languages, useTranslations, type Lang } from '../../../i18n/ui';
import capabilities from '../../../data/capabilities.json';

export function getStaticPaths() {
	return languages
		.filter((l) => l.code !== 'en')
		.map((l) => ({ params: { lang: l.code } }));
}

const { lang } = Astro.params;
const _t = useTranslations(lang as Lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const _homeHref = `${base}/${lang}/`;
const _count = capabilities.counts.packages;
---

<Base lang={lang as Lang} title={`${t.plugins.title} — @mcp-vertex/core`}>
	<section class="subhero">
		<div class="container">
			<nav class="subhero__crumb" aria-label="breadcrumb">
				<a href={homeHref}>{t.nav.concept}</a>
				<span aria-hidden="true">›</span>
				<span aria-current="page">{t.plugins.title}</span>
			</nav>
			<h1 transition:name="page-title" transition:animate="fade">{t.plugins.title}</h1>
			<p class="subhero__lead">{t.plugins.lead}</p>
			<div class="subhero__meta">
				<span><b>{count}</b>{t.tools.packages}</span>
			</div>
			<div class="subhero__ctas">
				<a class="btn btn--ghost" href={`${base}/${lang}/tools`}>{t.nav.tools} →</a>
				<a class="btn btn--ghost" href={`${base}/${lang}/install`}>{t.nav.install} →</a>
			</div>
		</div>
	</section>
	<PluginsSection lang={lang as Lang} />
</Base>