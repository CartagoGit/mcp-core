---
import Base from '#LAYOUTS/Base.astro';
import PageHeader from '#COMPONENTS/PageHeader.astro';
import { loopDetectorTranslations } from '#DATA/loop-detector-i18n';
import { languages, type Lang } from '#I18N/ui';

export function getStaticPaths() {
	return languages
		.filter((l) => l.code !== 'en')
		.map((l) => ({ params: { lang: l.code } }));
}

const { lang } = Astro.params;
const langCode: Lang = (
	lang && languages.some((l) => l.code === lang) ? lang : 'en'
) as Lang;

const t = loopDetectorTranslations[langCode] ?? loopDetectorTranslations.en!;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base lang={langCode} title={`${t.title} — @mcp-vertex/core`} description={t.subtitle}>
	<PageHeader
		lang={langCode}
		title={t.title}
		crumbs={[{ label: 'Plugins', href: langCode === 'en' ? `${base}/plugins` : `${base}/${langCode}/plugins` }]}
	/>
	<section class="section">
		<div class="container guide">
			<article class="guide__body">
				<p class="lead">{t.subtitle}</p>

				<h2>{t.overviewTitle}</h2>
				<p>{t.overviewBody1}</p>
				<p>{t.overviewBody2}</p>

				<h2>{t.signalsTitle}</h2>
				<h3>{t.signalsRepeatTitle}</h3>
				<p>{t.signalsRepeatDesc}</p>
				<h3>{t.signalsProgressTitle}</h3>
				<p>{t.signalsProgressDesc}</p>

				<h2>{t.configTitle}</h2>
				<p>{t.configDesc}</p>
				<pre><code>{`{
  "loopDetector": {
    "enabled": true,
    "repeatThreshold": 3,
    "noProgressThreshold": 3,
    "handoffDir": ".mcp-vertex/handoff"
  }
}`}</code></pre>

				<h2>{t.handoffTitle}</h2>
				<p>{t.handoffDesc}</p>

				<div style="margin-top: 2rem;">
					<a href={langCode === 'en' ? `${base}/plugins` : `${base}/${langCode}/plugins`}>
						← {t.backToPlugins}
					</a>
				</div>
			</article>
		</div>
	</section>
</Base>
