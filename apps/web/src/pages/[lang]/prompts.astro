---
/**
 * pages/[lang]/prompts.astro — translated `/<lang>/prompts` index.
 * See `tools.astro` for the shell recipe.
 */
import PromptsSection from '#COMPONENTS/PromptsSection.astro';
import PageShell from '#COMPONENTS/PageShell.astro';
import { langStaticPaths, resolveLang, localePath } from '#LIB/page';
import { useTranslations } from '#I18N/ui';

export const getStaticPaths = langStaticPaths;

const lang = resolveLang(Astro.params.lang);
const t = useTranslations(lang);
---

<PageShell
	lang={lang}
	title={t.prompts.title}
	base={import.meta.env.BASE_URL.replace(/\/$/, '')}
	crumbs={[{ label: t.nav.prompts, href: localePath(lang, 'prompts') }]}
>
	<PromptsSection lang={lang} heading={t.prompts.title} />
</PageShell>
