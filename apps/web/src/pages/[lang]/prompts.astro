---
import PromptsSection from '../../components/PromptsSection.astro';
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import { languages, useTranslations, type Lang } from '../../i18n/ui';
import capabilities from '../../data/capabilities.json';

export function getStaticPaths() {
	return languages
		.filter((l) => l.code !== 'en')
		.map((l) => ({ params: { lang: l.code } }));
}

const { lang } = Astro.params;
// Runtime guard: never render lang="undefined" (was the root cause of
// "switching language only translates the home page" — Astro fell back
// to English silently). Same pattern as index.astro, guide.astro and
// plugins/[plugin].astro.
const langCode: Lang = (
	lang && languages.some((l) => l.code === lang) ? lang : 'en'
) as Lang;
const t = useTranslations(langCode);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = `${base}/${langCode}/`;
const count = capabilities.counts.prompts ?? 0;
---

<Base lang={langCode} title={`${t.prompts.title} — @mcp-vertex/core`}>
	<PageHeader lang={langCode} title={t.prompts.title} />
	<PromptsSection lang={langCode} />
</Base>
