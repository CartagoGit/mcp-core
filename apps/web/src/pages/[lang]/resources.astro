---
/**
 * pages/[lang]/resources.astro — translated `/<lang>/resources` index.
 * See `tools.astro` for the shell recipe.
 */
import ResourcesSection from '#COMPONENTS/ResourcesSection.astro';
import PageShell from '#COMPONENTS/PageShell.astro';
import { langStaticPaths, resolveLang, localePath } from '#LIB/page';
import { useTranslations } from '#I18N/ui';

export const getStaticPaths = langStaticPaths;

const lang = resolveLang(Astro.params.lang);
const t = useTranslations(lang);
---

<PageShell
	lang={lang}
	title={t.resources.title}
	base={import.meta.env.BASE_URL.replace(/\/$/, '')}
	crumbs={[{ label: t.nav.resources, href: localePath(lang, 'resources') }]}
>
	<ResourcesSection lang={lang} heading={t.resources.title} />
</PageShell>
