---
import ResourcesSection from '../../components/ResourcesSection.astro';
import Base from '../../layouts/Base.astro';
import { languages, useTranslations, type Lang } from '../../i18n/ui';
import capabilities from '../../data/capabilities.json';

export function getStaticPaths() {
	return languages
		.filter((l) => l.code !== 'en')
		.map((l) => ({ params: { lang: l.code } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as Lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = `${base}/${lang}/`;
const count = capabilities.counts.resources ?? 0;
---

<Base lang={lang as Lang} title={`${t.resources.title} — @mcp-vertex/core`}>
	<section class="subhero">
		<div class="container">
			<nav class="subhero__crumb" aria-label="breadcrumb">
				<a href={homeHref}>{t.nav.concept}</a>
				<span aria-hidden="true">›</span>
				<span aria-current="page">{t.resources.title}</span>
			</nav>
			<h1 transition:name="page-title" transition:animate="fade">{t.resources.title}</h1>
			<p class="subhero__lead">{t.resources.lead}</p>
			<div class="subhero__meta">
				<span class="subhero__meta-item"><b>{count}</b>{t.resources.count}</span>
			</div>
			<div class="subhero__ctas">
				<a class="btn btn--ghost" href={`${base}/${lang}/prompts`}>{t.nav.prompts} →</a>
				<a class="btn btn--ghost" href={`${base}/${lang}/tools`}>{t.nav.tools} →</a>
			</div>
		</div>
	</section>
	<ResourcesSection lang={lang as Lang} />
</Base>
