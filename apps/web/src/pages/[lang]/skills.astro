---
import SkillsSection from '#COMPONENTS/SkillsSection.astro';
import Base from '#LAYOUTS/Base.astro';
import { languages, useTranslations, type Lang } from '#I18N/ui';
import skillsData from '#MANIFESTS/skills.json';

export function getStaticPaths() {
	return languages
		.filter((l) => l.code !== 'en')
		.map((l) => ({ params: { lang: l.code } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as Lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = `${base}/${lang}/`;
const count = (skillsData.skills ?? []).length;
---

<Base lang={lang as Lang} title={`${t.skills.title} — @mcp-vertex/core`}>
	<SkillsSection lang={lang as Lang} heading={t.skills.title} />
</Base>
