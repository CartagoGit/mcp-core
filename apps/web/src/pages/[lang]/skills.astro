---
import Base from '../../layouts/Base.astro';
import SkillsSection from '../../components/SkillsSection.astro';
import { languages, useTranslations, type Lang } from '../../i18n/ui';
import skillsData from '../../data/skills.json';

export function getStaticPaths() {
	return languages
		.filter((l) => l.code !== 'en')
		.map((l) => ({ params: { lang: l.code } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as Lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = `${base}/${lang}/`;
const count = (skillsData.skills ?? []).length;
---

<Base lang={lang as Lang} title={`${t.skills.title} — @mcp-vertex/core`}>
	<section class="subhero">
		<div class="container">
			<nav class="subhero__crumb" aria-label="breadcrumb">
				<a href={homeHref}>{t.nav.concept}</a>
				<span aria-hidden="true">›</span>
				<span aria-current="page">{t.skills.title}</span>
			</nav>
			<h1 transition:name="page-title" transition:animate="fade">{t.skills.title}</h1>
			<p class="subhero__lead">{t.skills.lead}</p>
			<div class="subhero__meta">
				<span><b>{count}</b>{t.skills.count}</span>
			</div>
			<div class="subhero__ctas">
				<a class="btn btn--ghost" href={`${base}/${lang}/tools`}>{t.nav.tools} →</a>
				<a class="btn btn--ghost" href={`${base}/${lang}/plugins`}>{t.nav.plugins} →</a>
			</div>
		</div>
	</section>
	<SkillsSection lang={lang as Lang} />
</Base>