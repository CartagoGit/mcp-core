---
/**
 * `/[lang]/skills` — localized skills index. See
 * `pages/[lang]/tools.astro` for the recipe.
 */
import SkillsSection from '#COMPONENTS/SkillsSection.astro';
import PageShell from '#COMPONENTS/PageShell.astro';
import { langStaticPaths, resolveLang, localePath } from '#LIB/page';
import { useTranslations } from '#I18N/ui';

export const getStaticPaths = langStaticPaths;

const lang = resolveLang(Astro.params.lang);
const t = useTranslations(lang);
---

<PageShell
	lang={lang}
	title={t.skills.title}
	base={import.meta.env.BASE_URL.replace(/\/$/, '')}
	crumbs={[{ label: t.nav.skills, href: localePath(lang, 'skills') }]}
>
	<SkillsSection lang={lang} heading={t.skills.title} />
</PageShell>
