---
import SkillsSection from '../../components/SkillsSection.astro';
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import { languages, useTranslations, type Lang } from '../../i18n/ui';
import skillsData from '../../data/skills.json';

export function getStaticPaths() {
	return languages
		.filter((l) => l.code !== 'en')
		.map((l) => ({ params: { lang: l.code } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as Lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = `${base}/${lang}/`;
const count = (skillsData.skills ?? []).length;
---

<Base lang={lang as Lang} title={`${t.skills.title} — @mcp-vertex/core`}>
	<PageHeader lang={lang as Lang} title={t.skills.title} />
	<SkillsSection lang={lang as Lang} />
</Base>
