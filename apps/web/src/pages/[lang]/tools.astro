---
import Base from '../../layouts/Base.astro';
import ToolsSection from '../../components/ToolsSection.astro';
import { languages, useTranslations, type Lang } from '../../i18n/ui';
import capabilities from '../../data/capabilities.json';

/** All non-English locales get their own /<lang>/tools. The English copy
 * lives in the root /tools.astro (so the project-site URL stays clean). */
export function getStaticPaths() {
	return languages
		.filter((l) => l.code !== 'en')
		.map((l) => ({ params: { lang: l.code } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as Lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = `${base}/${lang}/`;
---

<Base lang={lang as Lang} title={`${t.tools.title} — @mcp-vertex/core`}>
	<section class="subhero">
		<div class="container">
			<nav class="subhero__crumb" aria-label="breadcrumb">
				<a href={homeHref}>{t.nav.concept}</a>
				<span aria-hidden="true">›</span>
				<span aria-current="page">{t.tools.title}</span>
			</nav>
			<h1 transition:name="page-title" transition:animate="fade">{t.tools.title}</h1>
			<p class="subhero__lead">{t.tools.lead}</p>
			<div class="subhero__meta">
				<span><b>{capabilities.counts.tools}</b>{t.tools.count}</span>
				<span><b>{capabilities.counts.packages}</b>{t.tools.packages}</span>
			</div>
			<div class="subhero__ctas">
				<a class="btn btn--ghost" href={`${base}/${lang}/plugins`}>{t.nav.plugins} →</a>
				<a class="btn btn--ghost" href={`${base}/${lang}/install`}>{t.nav.install} →</a>
			</div>
		</div>
	</section>
	<ToolsSection lang={lang as Lang} />
</Base>