---
import ToolsSection from '#COMPONENTS/ToolsSection.astro';
import Base from '#LAYOUTS/Base.astro';
import { languages, useTranslations, type Lang } from '#I18N/ui';
import capabilities from '#MANIFESTS/capabilities.json';

/** All non-English locales get their own /<lang>/tools. The English copy
 * lives in the root /tools.astro (so the project-site URL stays clean). */
export function getStaticPaths() {
	return languages
		.filter((l) => l.code !== 'en')
		.map((l) => ({ params: { lang: l.code } }));
}

const { lang } = Astro.params;
// Runtime guard: never render lang="undefined" (was the root cause of
// "switching language only translates the home page" — Astro fell back
// to English silently). Same pattern as index.astro, guide.astro and
// plugins/[plugin].astro.
const langCode: Lang = (
	lang && languages.some((l) => l.code === lang) ? lang : 'en'
) as Lang;
const t = useTranslations(langCode);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = `${base}/${langCode}/`;
---

<Base lang={langCode} title={`${t.tools.title} — @mcp-vertex/core`}>
	<ToolsSection lang={langCode} heading={t.tools.title} />
</Base>
