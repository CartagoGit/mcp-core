---
import ToolPage from '#COMPONENTS/ToolPage.astro';
import Base from '#LAYOUTS/Base.astro';
import capabilities from '#MANIFESTS/capabilities.json';
import { languages, type Lang } from '#I18N/ui';

export function getStaticPaths() {
	const slugOf = (name: string) => name.replace('@mcp-vertex/', '');
	const nsFor = (s: string) => (s === 'core' ? 'mcp-vertex' : s);
	const pkgs = capabilities.packages as Array<{ name: string }>;
	const tools = capabilities.tools as Array<{
		name: string;
		namespace: string;
	}>;
	const langs = languages.map((l) => l.code).filter((c) => c !== 'en');
	const entries = pkgs.flatMap((p) => {
		const slug = slugOf(p.name);
		const ns = nsFor(slug);
		return tools
			.filter((t) => t.namespace === ns)
			.map((t) => ({ plugin: slug, tool: t.name }));
	});
	return langs.flatMap((lang) =>
		entries.map(({ plugin, tool }) => ({ params: { lang, plugin, tool } })),
	);
}

const { lang, plugin, tool } = Astro.params;
const langCode: Lang = (
	lang && languages.some((l) => l.code === lang) ? lang : 'en'
) as Lang;
---

<Base lang={langCode} title={`${tool} — @mcp-vertex/core`}>
	<ToolPage lang={langCode} toolName={tool!} />
</Base>
