---
/**
 * pages/[lang]/troubleshooting/index.astro — translated `/<lang>/troubleshooting`.
 * See `tools.astro` for the shell recipe.
 */
import TroubleshootingIndex from '#COMPONENTS/TroubleshootingIndex.astro';
import PageShell from '#COMPONENTS/PageShell.astro';
import { langStaticPaths, resolveLang, localePath } from '#LIB/page';
import { useTranslations } from '#I18N/ui';

export const getStaticPaths = langStaticPaths;

const lang = resolveLang(Astro.params.lang);
const t = useTranslations(lang);
---

<PageShell
	lang={lang}
	title={t.troubleshooting.title}
	base={import.meta.env.BASE_URL.replace(/\/$/, '')}
	crumbs={[{ label: t.nav.troubleshooting, href: localePath(lang, 'troubleshooting') }]}
>
	<TroubleshootingIndex lang={lang} />
</PageShell>
