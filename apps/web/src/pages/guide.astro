---
/**
 * pages/guide.astro — detailed project guide (f00048 S4).
 *
 * The "wiki": a single long page with a sticky scroll-spy TOC on the left
 * and the article on the right. Reuses the shared UI primitives
 * (`CodeBlock`, `Callout`, `Stepper`) so the guide reads in the same
 * visual language as `/install` and `/first-5-minutes`.
 *
 * Each section is wrapped in `<section id="..." class="guide__section">`
 * with a leading `<h2>`. The TOC is a single `<ol>` of anchor links whose
 * `aria-current` is toggled by the scroll-spy controller. A small inline
 * `<script>` runs IntersectionObserver to keep the active item in sync.
 */
import Base from '#LAYOUTS/Base.astro';
import CodeBlock from '#UI/CodeBlock.astro';
import Callout from '#UI/Callout.astro';
import Stepper from '#UI/Stepper.astro';
import { type Lang } from '#I18N/ui';

const lang: Lang = 'en';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Single source of truth for the TOC. Order = render order in the article.
const sections: ReadonlyArray<{ id: string; title: string }> = [
	{ id: 'intro', title: '1. Introduction' },
	{ id: 'concepts', title: '2. Concepts' },
	{ id: 'install', title: '3. Install' },
	{ id: 'config', title: '4. Configuration' },
	{ id: 'plugins', title: '5. Plugins' },
	{ id: 'capabilities', title: '6. Tools / Prompts / Resources / Knowledge' },
	{ id: 'skills', title: '7. Skills' },
	{ id: 'i18n', title: '8. i18n' },
	{ id: 'quality', title: '9. Quality gates & multi-language' },
	{ id: 'extending', title: '10. Extending mcp-vertex' },
	{ id: 'tokens', title: '11. Token budgets' },
	{ id: 'transitions', title: '12. View transitions' },
	{ id: 'faq', title: '13. FAQ' },
];
---

<Base
	lang={lang}
	title={`Guide — @mcp-vertex/core`}
	description="A detailed walkthrough of the @mcp-vertex/core project: concepts, install, config, plugins, quality gates, extending, FAQ."
>
	<section class="section">
		<div class="container">
			<h1>Guide</h1>
			<p class="lead">
				The full picture of <code>@mcp-vertex/core</code>: how the pieces fit,
				how to install, how to extend, and where the seams are.
			</p>

			<div class="guide">
				<aside class="guide__toc" aria-label="Table of contents">
					<strong>Contents</strong>
					<ol>
						{
							sections.map((s) => (
								<li>
									<a
										href={`#${s.id}`}
										data-toc-link={s.id}
										aria-current="false"
									>
										{s.title}
									</a>
								</li>
							))
						}
					</ol>
				</aside>

				<article class="guide__body">
					<section id="intro" class="guide__section">
						<h2>1. Introduction</h2>
						<p>
							<code>@mcp-vertex/core</code> is a project-agnostic
							<strong>Model Context Protocol</strong> server core + CLI plugin loader.
							The core knows nothing about your domain; capabilities ship as
							plugins you load on demand. The same plugin behaves identically under
							any host, IDE, or model.
						</p>
						<p>
							Read <a href={`${base}/`}>the home page</a> for the elevator pitch,
							or jump to <a href="#install">install</a> for the 1-minute version.
						</p>
					</section>

					<section id="concepts" class="guide__section">
						<h2>2. Concepts</h2>
						<ul>
							<li><strong>Core</strong>: a small MCP server that registers tools, prompts, resources, knowledge.</li>
							<li><strong>Plugin</strong>: an npm package exporting <code>IMcpPlugin</code>. Adds tools, prompts, knowledge, or skills.</li>
							<li><strong>Preset</strong>: a curated list of plugins (<code>minimal</code>, <code>standard</code>, <code>swarm</code>).</li>
							<li><strong>Capability</strong>: a tool, prompt, resource or knowledge entry exposed by a plugin.</li>
							<li><strong>Token budget</strong>: a measured ceiling on the bytes the server emits per response. A CI test guards regressions.</li>
						</ul>
					</section>

					<section id="install" class="guide__section">
						<h2>3. Install</h2>
						<p>
							See <a href={`${base}/install`}>the install page</a> for the full
							matrix (every package manager × every IDE). TL;DR:
						</p>
						<CodeBlock
							code="bunx @mcp-vertex/core init"
							lang="bash"
							caption="One-command installer (auto-detects your IDE)"
							filename="terminal"
							lang_label={lang}
						/>
						<CodeBlock
							code="bunx @mcp-vertex/core --check"
							lang="bash"
							caption="Self-diagnose the install"
							filename="verify"
							lang_label={lang}
						/>
					</section>

					<section id="config" class="guide__section">
						<h2>4. Configuration</h2>
						<p>
							Place a <code>mcp-vertex.config.json</code> at the workspace root.
							The loader auto-detects it. Schema lives at
							<code>packages/core/schema/mcp-vertex.config.schema.json</code>.
						</p>
						<CodeBlock
							code={`{
  "cacheDir": ".cache/mcp-vertex",
  "docsDir": "docs/mcp-vertex",
  "plugins": {
    "memory": { "options": { "ttlSeconds": 86400 } },
    "proposals": { "prefix": "work" }
  }
}`}
							lang="json"
							filename="mcp-vertex.config.json"
							lang_label={lang}
						/>
						<Callout variant="tip" lang_label={lang}>
							Project-local <code>mcp-vertex.config.json</code> wins over any
							user-global config — a single repo can be developed by many
							contributors without stepping on each other.
						</Callout>
					</section>

					<section id="plugins" class="guide__section">
						<h2>5. Plugins</h2>
						<p>
							See the
							<a href={`${base}/plugins`}>plugin index</a> for the full, live list. The
							short version:
						</p>
						<ul>
							<li><code>git</code>, <code>search</code>, <code>memory</code>, <code>docs</code>, <code>rules</code>, <code>quality</code>, <code>deps</code> — base toolkit (preset <code>standard</code>).</li>
							<li><code>proposals</code>, <code>notification</code>, <code>status-marker</code> — multi-agent coordination (preset <code>swarm</code>).</li>
						</ul>
						<p>
							Load with <code>--plugins=...</code> or <code>--preset=...</code>.
							Drop plugins from a preset with <code>--exclude-plugins=...</code>.
						</p>
					</section>

					<section id="capabilities" class="guide__section">
						<h2>6. Tools / Prompts / Resources / Knowledge</h2>
						<p>
							Each plugin can contribute any of the four capability types. The
							<a href={`${base}/tools`}>tools page</a> lists them live from the
							registry. See also
							<a href={`${base}/prompts`}>prompts</a>,
							<a href={`${base}/resources`}>resources</a>,
							<a href={`${base}/knowledge`}>knowledge</a>.
						</p>
					</section>

					<section id="skills" class="guide__section">
						<h2>7. Skills</h2>
						<p>
							Skills are markdown documents under
							<code>docs/mcp-vertex/skills/&lt;name&gt;/SKILL.md</code> that the agent can load
							on demand. See
							<a href={`${base}/skills`}>the skills page</a> for the live list.
						</p>
					</section>

					<section id="i18n" class="guide__section">
						<h2>8. i18n</h2>
						<p>
							The web UI is translated to 12 languages. Source of truth is
							<code>apps/web/src/i18n/langs/&lt;code&gt;.ts</code>. The
							<code>bun run check:i18n</code> gate ensures every language has
							every top-level key.
						</p>
					</section>

					<section id="quality" class="guide__section">
						<h2>9. Quality gates &amp; multi-language</h2>
						<p>
							Out of the box, <code>bun run validate</code> runs
							<code>typecheck</code> (TS), <code>lint</code> (Biome),
							<code>lint:scss</code> (Stylelint), and
							<code>test</code> (Vitest). The <code>quality</code> plugin exposes
							three MCP tools an agent can call at any time to scope and run
							project-defined gates:
						</p>
						<ul>
							<li><code>get_quality_scopes</code> — list the configured scopes
							and the exact commands each will run. Read-only.</li>
							<li><code>run_quality</code> — run a scope and return
							<code>&#123; ok, results: [&#123; command, ok, code, tail &#125;] &#125;</code>.
							Commands are spawned via <code>shell</code>; the runner
							measures the real exit code, never throws, and is cancellable.</li>
							<li><code>quality_cancel</code> — abort any in-flight run by PID
							(or all) instead of waiting for the timeout.</li>
						</ul>
						<p>
							<strong>The architecture is already language-agnostic.</strong> The
							core defines <code>IValidationCommand = &#123; command, expect &#125;</code>
							and <code>IValidationMatrix = &#123; scopes: Record&lt;string, IValidationCommand[]&gt; &#125;</code>
							(both re-exported from <code>@mcp-vertex/core/public</code>), and
							the JSON schema in <code>mcp-vertex.config.json</code> validates
							the shape. Any command that returns exit-code 0 works —
							<code>tsc</code>, <code>mypy</code>, <code>cargo check</code>,
							<code>go vet</code>, <code>ruff</code>, <code>detekt</code>,
							<code>shellcheck</code>, etc.
						</p>
						<p>Three sources of scopes, in precedence order:</p>
						<ol>
							<li>Plugin options — <code>quality.scopes = &#123; feature: ["..."] &#125;</code>.</li>
							<li><code>mcp-vertex.config.json</code> →
							<code>validationMatrix.scopes</code> (the canonical surface).</li>
							<li>Detected <code>package.json</code> scripts
							(<code>lint</code>, <code>typecheck</code>, <code>test</code>,
							<code>build</code>) folded into one <code>all</code> scope.</li>
						</ol>
						<p>Example — a polyglot project, with both TypeScript and Python
						gates in one config:</p>
						<CodeBlock
							code={`{
  "plugins": {
    "quality": { "options": {} }
  },
  "validationMatrix": {
    "scopes": {
      "typecheck": [
        { "command": "tsc --noEmit", "expect": "exit0" },
        { "command": "mypy .",      "expect": "exit0" }
      ],
      "lint": [
        { "command": "biome ci .",  "expect": "exit0" },
        { "command": "ruff check .", "expect": "exit0" }
      ],
      "test": [
        { "command": "vitest run",  "expect": "exit0" },
        { "command": "pytest -q",   "expect": "exit0" }
      ]
    }
  }
}`}
							lang="json"
							filename="mcp-vertex.config.json"
							lang_label={lang}
						/>
						<Callout variant="note" lang_label={lang}>
							For Rust and Go, swap the <code>typecheck</code> commands for
							<code>cargo check --all-targets</code> and
							<code>go vet ./...</code> respectively — the runner and schema
							don't care which binary runs, only that exit 0 means "pass". The
							core <strong>does not install</strong> any toolchain; your CI
							image or local dev shell is expected to provide them.
						</Callout>
						<p>
							<strong>Trust boundary:</strong> <code>run_quality</code>
							executes whatever the host config says. The commands come from
							<em>your</em> <code>mcp-vertex.config.json</code> or your plugin
							options — so the trust boundary is the host, not the agent. To
							harden a setup where a less-trusted agent can call
							<code>run_quality</code>, restrict which binaries may run with
							an allow/deny policy (enforced <em>before</em> any spawn; a
							blocked command is reported as failed with code 126, never
							executed):
						</p>
						<CodeBlock
							code={`{
  "plugins": {
    "quality": {
      "options": {
        "commandPolicy": {
          "allow": ["bun", "npm", "npx", "tsc", "vitest", "biome", "mypy", "ruff", "pytest"],
          "deny":  ["curl", "wget", "bash", "sh"]
        }
      }
    }
  }
}`}
							lang="json"
							filename="mcp-vertex.config.json"
							lang_label={lang}
						/>
						<p>
							See the <a href={`${base}/plugins`}>plugin index</a> for the
							<code>quality</code> plugin page, and the
							<a href={`${base}/tools`}>tools page</a> for the live registry
							of <code>quality_*</code> tools.
						</p>
					</section>

					<section id="extending" class="guide__section">
						<h2>10. Extending mcp-vertex</h2>
						<Stepper
							steps={[
								'Scaffold a plugin package (`bunx @mcp-vertex/core scaffold-plugin my-plugin`).',
								'Export `IMcpPlugin` from `src/index.ts` — declare your tools, prompts, knowledge, skills.',
								'Add the package to `mcp-vertex.config.json` under `plugins.<id>`.',
								'Run `bun run check` to validate the plugin shape and the i18n gate.',
							]}
						/>
						<p>
							See the
							<a href="https://github.com/CartagoGit/mcp-vertex/tree/main/docs/mcp-vertex/examples/custom-plugin">custom-plugin example</a>
							for a working starter (counts the words in a workspace).
						</p>
					</section>

					<section id="tokens" class="guide__section">
						<h2>11. Token budgets</h2>
						<p>
							Every public response shape is measured. The
							<code>overview (compact)</code> + <code>auto_work</code> cold-start
							fits in &lt; 300 tokens. A CI test fails if the budgets regress.
							See <a href={`${base}/benchmarks`}>benchmarks</a>.
						</p>
					</section>

					<section id="transitions" class="guide__section">
						<h2>12. View transitions</h2>
						<p>
							The site uses
							<a href="https://docs.astro.build/en/guides/view-transitions/">Astro
							View Transitions</a>: navigating between pages cross-fades instead
							of hard-reloading, and the page title morphs via
							<code>transition:name="page-title"</code>. Respects
							<code>prefers-reduced-motion</code>.
						</p>
					</section>

					<section id="faq" class="guide__section">
						<h2>13. FAQ</h2>
						<h3>How is this different from the official MCP SDK?</h3>
						<p>
							The official SDK gives you the protocol primitives; mcp-vertex
							gives you a project-agnostic <em>server</em> with a plugin loader,
							a tool registry, view transitions, and a measured token budget.
						</p>
						<h3>Does it work with my IDE?</h3>
						<p>
							Yes — the server is stdio MCP. Any MCP client (VS Code + Copilot
							Chat, Cursor, Windsurf, Claude Desktop, Claude Code, Antigravity,
							Zed) works. See <a href={`${base}/install`}>install</a>.
						</p>
						<h3>Is the core fast?</h3>
						<p>
							Yes. Boot is &lt; 100 ms. <code>overview (compact)</code> returns
							in &lt; 50 ms. Tests run in ~7 s on a clean checkout.
						</p>
					</section>
				</article>
			</div>
		</div>
	</section>
</Base>

<script>
	// Scroll-spy: as the user scrolls the article, mark the matching TOC link
	// as `aria-current="true"`. We pick the topmost section whose top is
	// above the viewport centre, falling back to the first section when
	// the page is scrolled to the very top. Idempotent across re-mounts
	// (e.g. after a view-transition swap): we rebuild the observer on each
	// `astro:page-load` and on first script run.
	const ROOT_SELECTOR = '.guide';
	const initScrollSpy = () => {
		const root = document.querySelector<HTMLElement>(ROOT_SELECTOR);
		if (!root) return;
		const links = Array.from(
			root.querySelectorAll<HTMLAnchorElement>('[data-toc-link]'),
		);
		const sections = links
			.map((a) => {
				const id = a.dataset.tocLink;
				if (!id) return null;
				const el = document.getElementById(id);
				return el ? { link: a, el } : null;
			})
			.filter((v): v is { link: HTMLAnchorElement; el: HTMLElement } => v !== null);
		if (sections.length === 0) return;

		const setActive = (id: string) => {
			for (const { link } of sections) {
				link.setAttribute(
					'aria-current',
					link.dataset.tocLink === id ? 'true' : 'false',
				);
			}
		};

		// Pick the section whose top is just above the activation line
		// (one third of the viewport down from the top — feels right for
		// long articles). Fall back to the first section.
		const onScroll = () => {
			const line = window.innerHeight / 3;
			let activeId = sections[0]?.el.id ?? '';
			for (const { el } of sections) {
				const r = el.getBoundingClientRect();
				if (r.top <= line) activeId = el.id;
				else break;
			}
			setActive(activeId);
		};
		onScroll();
		window.addEventListener('scroll', onScroll, { passive: true });
	};
	initScrollSpy();
	document.addEventListener('astro:page-load', initScrollSpy);
</script>

<style>
	.guide {
		display: grid;
		grid-template-columns: minmax(0, 14rem) minmax(0, 1fr);
		gap: 2.5rem;
		margin-top: 1.5rem;
	}
	.guide__toc {
		position: sticky;
		top: 5rem;
		align-self: start;
		max-height: calc(100vh - 6rem);
		overflow-y: auto;
		padding-right: 0.5rem;
		border-right: 1px solid var(--line);
	}
	.guide__toc strong {
		display: block;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--muted);
		margin-bottom: 0.5rem;
	}
	.guide__toc ol {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.15rem;
	}
	.guide__toc a {
		display: block;
		padding: 0.3rem 0.5rem;
		font-size: 0.88rem;
		border-radius: 6px;
		color: var(--muted);
		text-decoration: none;
		border-left: 2px solid transparent;
	}
	.guide__toc a:hover {
		color: var(--fg);
		background: color-mix(in srgb, currentColor 6%, transparent);
	}
	.guide__toc a[aria-current='true'] {
		color: var(--fg);
		font-weight: 600;
		background: color-mix(in srgb, currentColor 8%, transparent);
		border-left-color: currentColor;
	}
	.guide__body {
		max-width: 50rem;
	}
	.guide__section {
		padding: 1rem 0 2rem;
		border-bottom: 1px solid var(--line);
		scroll-margin-top: 5rem;
	}
	.guide__section:last-child {
		border-bottom: 0;
	}
	.guide__section h2 {
		margin: 0 0 1rem;
		font-size: clamp(1.4rem, 3.5vw, 1.8rem);
		letter-spacing: -0.015em;
	}
	.guide__section h3 {
		margin: 1.5rem 0 0.5rem;
		font-size: 1.1rem;
	}
	.guide__section p,
	.guide__section ul,
	.guide__section ol {
		line-height: 1.6;
	}
	@media (max-width: 800px) {
		.guide {
			grid-template-columns: 1fr;
		}
		.guide__toc {
			position: static;
			border-right: 0;
			border-bottom: 1px solid var(--line);
			max-height: none;
			padding-right: 0;
			padding-bottom: 0.5rem;
		}
	}
</style>
