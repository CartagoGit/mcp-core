---
import { useTranslations, type Lang } from '../i18n/ui';

const lang: Lang = 'en';
const _t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const _homeHref = `${base}/`;
---

<Base lang={lang} title={`${t.install.title} — @mcp-vertex/core`}>
	<section class="subhero">
		<div class="container">
			<nav class="subhero__crumb" aria-label="breadcrumb">
				<a href={homeHref}>{t.nav.concept}</a>
				<span aria-hidden="true">›</span>
				<span aria-current="page">{t.install.title}</span>
			</nav>
			<h1 transition:name="page-title" transition:animate="fade">{t.install.title}</h1>
			<p class="subhero__lead">{t.install.lead}</p>
			<div class="subhero__ctas">
				<a class="btn btn--primary" href={`${base}/tools`}>{t.nav.tools} →</a>
				<a class="btn btn--ghost" href={`${base}/plugins`}>{t.nav.plugins} →</a>
			</div>
		</div>
	</section>
	<Install lang={lang} />
</Base>