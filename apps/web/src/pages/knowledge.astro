---
import KnowledgeSection from '#COMPONENTS/KnowledgeSection.astro';
import Base from '#LAYOUTS/Base.astro';
import PageHeader from '#COMPONENTS/PageHeader.astro';
import { useTranslations, type Lang } from '#I18N/ui';
import capabilities from '#MANIFESTS/capabilities.json';

const lang: Lang = 'en';
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = `${base}/`;
const count = capabilities.counts.knowledge ?? 0;
---

<Base lang={lang} title={`${t.knowledge.title} — @mcp-vertex/core`}>
	<PageHeader lang={lang} title={t.knowledge.title} />
	<KnowledgeSection lang={lang} />
</Base>
