---
/**
 * `/knowledge` — English knowledge index. See `pages/tools.astro` for
 * the recipe.
 */
import KnowledgeSection from '#COMPONENTS/KnowledgeSection.astro';
import PageShell from '#COMPONENTS/PageShell.astro';
import { localePath } from '#LIB/page';
import { useTranslations } from '#I18N/ui';

const lang = 'en' as const;
const t = useTranslations(lang);
---

<PageShell
	lang={lang}
	title={t.knowledge.title}
	base={import.meta.env.BASE_URL.replace(/\/$/, '')}
	crumbs={[{ label: t.nav.knowledge, href: localePath(lang, 'knowledge') }]}
>
	<KnowledgeSection lang={lang} heading={t.knowledge.title} />
</PageShell>
