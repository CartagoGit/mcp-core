---
/**
 * `/plugins` — English plugins index. See `pages/tools.astro` for the
 * recipe.
 */
import PluginsSection from '#COMPONENTS/PluginsSection.astro';
import PageShell from '#COMPONENTS/PageShell.astro';
import { localePath } from '#LIB/page';
import { useTranslations } from '#I18N/ui';

const lang = 'en' as const;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<PageShell
	lang={lang}
	title={t.plugins.title}
	base={base}
	crumbs={[{ label: t.nav.plugins, href: localePath(lang, 'plugins') }]}
>
	<PluginsSection lang={lang} heading={t.plugins.title} />
	<p class="plugins-bridge">
		<a class="plugins-bridge__link" href={`${base}/capabilities`}>
			{t.tools.title} →
		</a>
	</p>
</PageShell>
