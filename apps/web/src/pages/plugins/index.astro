---
/**
 * `/plugins` — English plugins index. Same recipe as `/tools`: copy
 * this file, swap the Section and `t.<pageKey>` to add a new root page.
 */
import PluginsSection from '#COMPONENTS/PluginsSection.astro';
import PageShell from '#COMPONENTS/PageShell.astro';
import { localePath } from '#LIB/page';
import { useTranslations } from '#I18N/ui';

const lang = 'en' as const;
const t = useTranslations(lang);
---

<PageShell
	lang={lang}
	title={t.plugins.title}
	base={import.meta.env.BASE_URL.replace(/\/$/, '')}
	crumbs={[{ label: t.nav.plugins, href: localePath(lang, 'plugins') }]}
>
	<PluginsSection lang={lang} heading={t.plugins.title} />
</PageShell>
