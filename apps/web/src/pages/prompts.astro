---
/**
 * `/prompts` — English prompts index. See `pages/tools.astro` for the
 * recipe.
 */
import PromptsSection from '#COMPONENTS/PromptsSection.astro';
import PageShell from '#COMPONENTS/PageShell.astro';
import { localePath } from '#LIB/page';
import { useTranslations } from '#I18N/ui';

const lang = 'en' as const;
const t = useTranslations(lang);
---

<PageShell
	lang={lang}
	title={t.prompts.title}
	base={import.meta.env.BASE_URL.replace(/\/$/, '')}
	crumbs={[{ label: t.nav.prompts, href: localePath(lang, 'prompts') }]}
>
	<PromptsSection lang={lang} heading={t.prompts.title} />
</PageShell>
