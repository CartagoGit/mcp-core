---
import ResourcesSection from '#COMPONENTS/ResourcesSection.astro';
import Base from '#LAYOUTS/Base.astro';
import { useTranslations, type Lang } from '#I18N/ui';
import capabilities from '#MANIFESTS/capabilities.json';

const lang: Lang = 'en';
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = `${base}/`;
const count = capabilities.counts.resources ?? 0;
---

<Base lang={lang} title={`${t.resources.title} — @mcp-vertex/core`}>
	<ResourcesSection lang={lang} heading={t.resources.title} />
</Base>
