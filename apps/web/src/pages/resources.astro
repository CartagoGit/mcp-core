---
import ResourcesSection from '../components/ResourcesSection.astro';
import Base from '../layouts/Base.astro';
import { useTranslations, type Lang } from '../i18n/ui';
import capabilities from '../data/capabilities.json';

const lang: Lang = 'en';
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = `${base}/`;
const count = capabilities.counts.resources ?? 0;
---

<Base lang={lang} title={`${t.resources.title} — @mcp-vertex/core`}>
	<section class="subhero">
		<div class="container">
			<nav class="subhero__crumb" aria-label="breadcrumb">
				<a href={homeHref}>{t.nav.concept}</a>
				<span aria-hidden="true">›</span>
				<span aria-current="page">{t.resources.title}</span>
			</nav>
			<h1 transition:name="page-title" transition:animate="fade">{t.resources.title}</h1>
			<p class="subhero__lead">{t.resources.lead}</p>
			<div class="subhero__meta">
				<span><b>{count}</b>{t.resources.count}</span>
			</div>
			<div class="subhero__ctas">
				<a class="btn btn--ghost" href={`${base}/prompts`}>{t.nav.prompts} →</a>
				<a class="btn btn--ghost" href={`${base}/tools`}>{t.nav.tools} →</a>
			</div>
		</div>
	</section>
	<ResourcesSection lang={lang} />
</Base>
