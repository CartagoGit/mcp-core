---
/**
 * `/setup` — English setup page. See `pages/tools.astro` for the
 * recipe.
 */
import Setup from '#COMPONENTS/Setup.astro';
import PageShell from '#COMPONENTS/PageShell.astro';
import { localePath } from '#LIB/page';
import { useTranslations } from '#I18N/ui';

const lang = 'en' as const;
const t = useTranslations(lang);
---

<PageShell
	lang={lang}
	title={t.setup.title}
	base={import.meta.env.BASE_URL.replace(/\/$/, '')}
	crumbs={[{ label: t.nav.setup, href: localePath(lang, 'setup') }]}
>
	<Setup lang={lang} />
</PageShell>
