---
/**
 * `/skills` — English skills index. See `pages/tools.astro` for the
 * recipe.
 */
import SkillsSection from '#COMPONENTS/SkillsSection.astro';
import PageShell from '#COMPONENTS/PageShell.astro';
import { localePath } from '#LIB/page';
import { useTranslations } from '#I18N/ui';

const lang = 'en' as const;
const t = useTranslations(lang);
---

<PageShell
	lang={lang}
	title={t.skills.title}
	base={import.meta.env.BASE_URL.replace(/\/$/, '')}
	crumbs={[{ label: t.nav.skills, href: localePath(lang, 'skills') }]}
>
	<SkillsSection lang={lang} heading={t.skills.title} />
</PageShell>
