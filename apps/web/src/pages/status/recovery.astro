---
import PageHeader from '../../components/PageHeader.astro';
import RecoveryTable from '../../components/recovery/RecoveryTable.astro';
import Base from '../../layouts/Base.astro';
import { useTranslations, type Lang } from '../../i18n/ui';

const lang: Lang = 'en';
const t = useTranslations(lang);
---

<Base lang={lang} title={`${t.recovery.title} — @mcp-vertex/core`}>
	<PageHeader lang={lang} title={t.recovery.title} />
	<section class="section">
		<div class="container">
			<p>{t.recovery.lead}</p>
			<RecoveryTable labels={t.recovery} />
		</div>
	</section>
	<script>
		const source = new EventSource('/api/events/agent-dead');
		source.addEventListener('agent-dead', () => {
			window.location.reload();
		});
		source.onerror = () => source.close();
	</script>
</Base>
