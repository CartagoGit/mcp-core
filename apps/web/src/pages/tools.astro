---
import ToolsSection from '#COMPONENTS/ToolsSection.astro';
import Base from '#LAYOUTS/Base.astro';
import PageHeader from '#COMPONENTS/PageHeader.astro';
import { useTranslations, type Lang } from '#I18N/ui';
import capabilities from '#MANIFESTS/capabilities.json';

const lang: Lang = 'en';
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = `${base}/`;
---

<Base lang={lang} title={`${t.tools.title} — @mcp-vertex/core`}>
	<PageHeader lang={lang} title={t.tools.title} />
	<ToolsSection lang={lang} />
</Base>
