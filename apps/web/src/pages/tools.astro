---
/**
 * `/tools` — English tools index. See `pages/tools.astro` for the
 * recipe.
 */
import ToolsSection from '#COMPONENTS/ToolsSection.astro';
import PageShell from '#COMPONENTS/PageShell.astro';
import { localePath } from '#LIB/page';
import { useTranslations } from '#I18N/ui';

const lang = 'en' as const;
const t = useTranslations(lang);
---

<PageShell
	lang={lang}
	title={t.tools.title}
	base={import.meta.env.BASE_URL.replace(/\/$/, '')}
	crumbs={[{ label: t.nav.tools, href: localePath(lang, 'tools') }]}
>
	<ToolsSection lang={lang} heading={t.tools.title} />
</PageShell>
