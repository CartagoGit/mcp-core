{
	"name": "@cartago-git/mcp-core-monorepo",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Project-agnostic MCP server core + CLI plugin loader. Publishes @cartago-git/mcp-core and its plugins.",
	"author": "Cartago",
	"license": "BSD-3-Clause",
	"workspaces": ["packages/*", "plugins/*", "apps/*", "examples/*"],
	"scripts": {
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"lint": "biome ci",
		"lint:fix": "biome lint --write",
		"build": "bun scripts/build.ts",
		"validate": "bun run typecheck && bun run lint && bun run test",
		"types:generate": "bun scripts/generate-tool-types.ts",
		"config:schema": "bun scripts/generate-config-schema.ts",
		"release": "bun scripts/release.ts",
		"smoke": "bun scripts/smoke-cli.ts",
		"docs:api": "typedoc",
		"site": "bun run docs:api && cd apps/web && bun run build",
		"site:strict": "bun run docs:api && cd apps/web && bun run build:strict"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@modelcontextprotocol/sdk": "1.29.0",
		"@types/bun": "latest",
		"@types/node": "^20.11.0",
		"@vitest/coverage-v8": "4.1.8",
		"typedoc": "^0.28.19",
		"typescript": "6.0.3",
		"vitest": "4.1.8",
		"zod": "^4.4.3"
	}
}
