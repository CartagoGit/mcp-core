{
	"name": "@cartago-git/mcp-core-monorepo",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Project-agnostic MCP server core + CLI plugin loader. Publishes @cartago-git/mcp-core and its plugins.",
	"author": "Cartago",
	"license": "BSD-3-Clause",
	"workspaces": ["packages/*", "plugins/*"],
	"scripts": {
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"build": "bun scripts/build.ts",
		"validate": "bun run typecheck && bun run test",
		"types:generate": "bun scripts/generate-tool-types.ts",
		"release": "bun scripts/release.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@types/bun": "latest",
		"@types/node": "^20.11.0",
		"@vitest/coverage-v8": "4.1.8",
		"typescript": "6.0.3",
		"vitest": "4.1.8",
		"zod": "^4.4.3"
	}
}
