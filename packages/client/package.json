{
	"name": "@mcp-vertex/client",
	"version": "0.1.0",
	"type": "module",
	"description": "IDE-agnostic TypeScript client for talking to an mcp-vertex server over MCP stdio.",
	"author": "Cartago",
	"license": "BSD-3-Clause",
	"keywords": [
		"mcp",
		"model-context-protocol",
		"client",
		"ide",
		"mcp-vertex"
	],
	"main": "./dist/index.js",
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"exports": {
		".": {
			"@mcp-vertex/source": {
				"types": "./src/index.ts"
			},
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./public": {
			"@mcp-vertex/source": {
				"types": "./src/public/index.ts"
			},
			"types": "./dist/public/index.d.ts",
			"import": "./dist/public/index.js"
		}
	},
	"scripts": {
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"build": "bun ../../scripts/build.ts packages/client"
	},
	"dependencies": {
		"@mcp-vertex/core": "workspace:*",
		"@modelcontextprotocol/sdk": "^1.29.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "6.0.3",
		"vitest": "4.1.8"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/CartagoGit/mcp-vertex"
	},
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts"
}
