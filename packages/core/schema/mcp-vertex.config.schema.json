{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"type": "object",
	"properties": {
		"$schema": {
			"type": "string"
		},
		"cacheDir": {
			"type": "string"
		},
		"docsDir": {
			"type": "string"
		},
		"keepLegacy": {
			"type": "boolean"
		},
		"agentWorktree": {
			"type": "boolean"
		},
		"convention": {
			"type": "object",
			"properties": {
				"pluginPathsRoot": {
					"type": "string"
				},
				"sourceRoot": {
					"type": "string"
				}
			},
			"required": [
				"pluginPathsRoot",
				"sourceRoot"
			],
			"additionalProperties": false
		},
		"filesystem": {
			"type": "object",
			"properties": {
				"authorizedRoots": {
					"type": "array",
					"items": {
						"type": "string"
					}
				}
			},
			"additionalProperties": false
		},
		"commitAuthor": {
			"type": "object",
			"properties": {
				"mode": {
					"type": "string",
					"enum": [
						"git",
						"agent",
						"bot",
						"named"
					]
				},
				"clientName": {
					"type": "string"
				},
				"modelName": {
					"type": "string"
				},
				"humanName": {
					"type": "string"
				},
				"humanEmail": {
					"type": "string"
				}
			},
			"additionalProperties": false
		},
		"validationMatrix": {
			"type": "object",
			"properties": {
				"scopes": {
					"type": "object",
					"propertyNames": {
						"type": "string"
					},
					"additionalProperties": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"command": {
									"type": "string"
								},
								"expect": {
									"type": "string"
								}
							},
							"required": [
								"command",
								"expect"
							],
							"additionalProperties": false
						}
					}
				}
			},
			"required": [
				"scopes"
			],
			"additionalProperties": false
		},
		"plugins": {
			"type": "object",
			"propertyNames": {
				"type": "string"
			},
			"additionalProperties": {
				"type": "object",
				"properties": {
					"prefix": {
						"type": "string"
					},
					"options": {
						"type": "object",
						"propertyNames": {
							"type": "string"
						},
						"additionalProperties": {}
					},
					"path": {
						"type": "string"
					}
				},
				"additionalProperties": false
			}
		},
		"cache": {
			"type": "object",
			"properties": {
				"runOnBoot": {
					"type": "string",
					"enum": [
						"dry-run",
						"apply",
						"off"
					]
				},
				"maxAgeDays": {
					"type": "number"
				},
				"worktrees": {
					"type": "object",
					"properties": {
						"enabled": {
							"type": "boolean"
						},
						"keepLastN": {
							"type": "number"
						}
					},
					"additionalProperties": false
				}
			},
			"additionalProperties": false
		},
		"loopDetector": {
			"type": "object",
			"properties": {
				"enabled": {
					"type": "boolean"
				},
				"repeatThreshold": {
					"type": "number"
				},
				"nearRepeatThreshold": {
					"type": "number"
				},
				"similarityThreshold": {
					"type": "number"
				},
				"idleThreshold": {
					"type": "number"
				},
				"noProgressThreshold": {
					"type": "number"
				},
				"ringSize": {
					"type": "number"
				},
				"gitCheckTools": {
					"type": "array",
					"items": {
						"type": "string"
					}
				},
				"handoffDir": {
					"type": "string"
				},
				"handoffTtlDays": {
					"type": "number"
				},
				"notifyOnDetect": {
					"type": "boolean"
				},
				"interactiveAgentPatterns": {
					"type": "array",
					"items": {
						"type": "string"
					}
				}
			},
			"additionalProperties": false
		},
		"bootstrap": {
			"type": "object",
			"properties": {
				"patternOverrides": {
					"type": "object",
					"propertyNames": {
						"type": "string"
					},
					"additionalProperties": {
						"type": "object",
						"properties": {
							"type": {
								"type": "string"
							},
							"describe": {
								"type": "string"
							},
							"recommendedTools": {
								"type": "array",
								"items": {
									"type": "object",
									"properties": {
										"name": {
											"type": "string"
										},
										"description": {
											"type": "string"
										}
									},
									"required": [
										"name",
										"description"
									],
									"additionalProperties": false
								}
							},
							"recommendedPlugins": {
								"type": "array",
								"items": {
									"type": "string"
								}
							},
							"knowledgeHints": {
								"type": "array",
								"items": {
									"type": "string"
								}
							}
						},
						"required": [
							"type",
							"describe",
							"recommendedTools",
							"recommendedPlugins",
							"knowledgeHints"
						],
						"additionalProperties": false
					}
				}
			},
			"additionalProperties": false
		}
	},
	"additionalProperties": false,
	"$id": "https://cartagogit.github.io/mcp-vertex/mcp-vertex.config.schema.json",
	"title": "mcp-vertex.config.json",
	"description": "Configuration for @mcp-vertex/core: cache/docs roots, the quality-gate validation matrix, and per-plugin prefix/options."
}
