{
	"name": "@mcp-vertex/cache",
	"version": "0.1.0",
	"type": "module",
	"description": "Opt-in cache eviction plugin: declares static TTL/keep-last rules for the shared `.cache/mcp-vertex` root and exposes `cache_gc` (dry-run by default) to preview or apply eviction. No network, no secrets. Load with `mcp-vertex --plugins=cache`.",
	"author": "Cartago",
	"license": "BSD-3-Clause",
	"keywords": [
		"mcp",
		"model-context-protocol",
		"agent",
		"cache",
		"eviction",
		"gc",
		"ttl",
		"cartago",
		"plugin"
	],
	"main": "./dist/index.js",
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"exports": {
		".": {
			"@mcp-vertex/source": {
				"types": "./src/index.ts"
			},
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./public": {
			"@mcp-vertex/source": {
				"types": "./src/public/index.ts"
			},
			"types": "./dist/public/index.d.ts",
			"import": "./dist/public/index.js"
		}
	},
	"scripts": {
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"build": "bun ../../scripts/build.ts plugins/cache"
	},
	"peerDependencies": {
		"@mcp-vertex/core": "^0.1.0"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@mcp-vertex/core": "workspace:*",
		"@types/bun": "latest",
		"typescript": "6.0.3",
		"vitest": "4.1.9"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/CartagoGit/mcp-vertex"
	},
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts"
}
