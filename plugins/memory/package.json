{
	"name": "@cartago-git/mcp-memory",
	"version": "0.1.0",
	"type": "module",
	"description": "Persistent project memory plugin for @cartago-git/mcp-core: save/recall/list/forget small notes under the cache dir, so agents keep continuity across sessions with minimal tokens. Load with `mcp-core --plugins=memory`.",
	"author": "Cartago",
	"license": "MIT",
	"keywords": ["mcp", "model-context-protocol", "memory", "agent", "ai", "cartago", "plugin"],
	"main": "./src/index.ts",
	"files": ["src", "README.md", "LICENSE"],
	"exports": {
		".": "./src/index.ts",
		"./public": "./src/public/index.ts",
		"./lib/*": "./src/lib/*.ts"
	},
	"scripts": {
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"@cartago-git/mcp-core": "^0.1.0"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@cartago-git/mcp-core": "workspace:*",
		"@types/bun": "latest",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	}
}
