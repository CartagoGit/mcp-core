{
	"name": "@cartago-git/mcp-proposals",
	"version": "0.1.0",
	"type": "module",
	"description": "Proposals workflow plugin for @cartago-git/mcp-core: a file-based proposal store (frontmatter, budgets, acceptance, parallelism, registry sync), file-level agent locks, a persistent task queue and multi-agent (swarm) orchestration. Load with `mcp-core --plugins=proposals`.",
	"author": "Cartago",
	"license": "MIT",
	"keywords": [
		"mcp",
		"model-context-protocol",
		"proposals",
		"swarm",
		"agent",
		"ai",
		"cartago",
		"plugin"
	],
	"main": "./src/index.ts",
	"files": [
		"src",
		"README.md",
		"LICENSE"
	],
	"exports": {
		".": "./src/index.ts",
		"./public": "./src/public/index.ts"
	},
	"scripts": {
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"@cartago-git/mcp-core": "^0.1.0"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@cartago-git/mcp-core": "workspace:*",
		"@types/bun": "latest",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/cartago-git/mcp-core"
	}
}
