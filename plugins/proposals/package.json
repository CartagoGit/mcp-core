{
	"name": "@cartago-git/mcp-proposals",
	"version": "0.1.0",
	"type": "module",
	"description": "Proposals workflow plugin for @cartago-git/mcp-core: a file-based proposal store (frontmatter, budgets, acceptance, parallelism, registry sync), file-level agent locks, a persistent task queue and multi-agent (swarm) orchestration. Load with `mcp-core --plugins=proposals`.",
	"author": "Cartago",
	"license": "BSD-3-Clause",
	"keywords": [
		"mcp",
		"model-context-protocol",
		"proposals",
		"swarm",
		"agent",
		"ai",
		"cartago",
		"plugin"
	],
	"main": "./dist/index.js",
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./public": {
			"types": "./dist/public/index.d.ts",
			"import": "./dist/public/index.js"
		}
	},
	"scripts": {
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"build": "bun ../../scripts/build.ts plugins/proposals"
	},
	"peerDependencies": {
		"@cartago-git/mcp-core": "^0.1.0"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@cartago-git/mcp-core": "workspace:*",
		"@types/bun": "latest",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/cartago-git/mcp-core"
	},
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts"
}
