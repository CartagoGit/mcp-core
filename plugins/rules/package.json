{
	"name": "@cartago-git/mcp-rules",
	"version": "0.1.0",
	"type": "module",
	"description": "Lint/type rules plugin for @cartago-git/mcp-core: ships per-framework default ESLint + TypeScript presets (Angular, React, Vue, Svelte, vanilla TS/JS, jQuery), detects each project area's framework, materialises the defaults to cache, and lets agents apply them with a configurable enforcement mode (strict/mixed/none/proposal) — the project's own config always wins. Load with `mcp-core --plugins=rules`.",
	"author": "Cartago",
	"license": "BSD-3-Clause",
	"keywords": [
		"mcp",
		"model-context-protocol",
		"eslint",
		"lint",
		"rules",
		"agent",
		"ai",
		"cartago",
		"plugin"
	],
	"main": "./dist/index.js",
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./public": {
			"types": "./dist/public/index.d.ts",
			"import": "./dist/public/index.js"
		}
	},
	"scripts": {
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"build": "bun ../../scripts/build.ts plugins/rules"
	},
	"peerDependencies": {
		"@cartago-git/mcp-core": "^0.1.0"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@cartago-git/mcp-core": "workspace:*",
		"@types/bun": "latest",
		"typescript": "6.0.3",
		"vitest": "4.1.8"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/cartago-git/mcp-core"
	},
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts"
}
