{
	"name": "@cartago-git/mcp-search",
	"version": "0.1.0",
	"type": "module",
	"description": "Textual workspace search plugin for @cartago-git/mcp-core: a grep-like `search` tool returning low-token {file,line,text} hits over allow-listed text files. Load with `mcp-core --plugins=search`.",
	"author": "Cartago",
	"license": "BSD-3-Clause",
	"keywords": [
		"mcp",
		"model-context-protocol",
		"search",
		"grep",
		"agent",
		"ai",
		"cartago",
		"plugin"
	],
	"main": "./src/index.ts",
	"files": [
		"src",
		"README.md",
		"LICENSE"
	],
	"exports": {
		".": "./src/index.ts",
		"./public": "./src/public/index.ts"
	},
	"scripts": {
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"@cartago-git/mcp-core": "^0.1.0"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@cartago-git/mcp-core": "workspace:*",
		"@types/bun": "latest",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/cartago-git/mcp-core"
	}
}
