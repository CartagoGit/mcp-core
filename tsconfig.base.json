{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2022"],
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"verbatimModuleSyntax": true,
		"noImplicitOverride": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitReturns": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"forceConsistentCasingInFileNames": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"declaration": false,
		"sourceMap": true,
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"customConditions": ["@mcp-vertex/source"],
		"types": ["bun", "node"],
		"paths": {
			"@mcp-vertex/core": ["./packages/core/src/index.ts"],
			"@mcp-vertex/core/public": ["./packages/core/src/public/index.ts"],
			"@mcp-vertex/core/*": ["./packages/core/src/*"],
			"@mcp-vertex/client": ["./packages/client/src/index.ts"],
			"@mcp-vertex/client/public": [
				"./packages/client/src/public/index.ts"
			],
			"@mcp-vertex/client/*": ["./packages/client/src/*"],
			"@mcp-vertex/ui-extension": [
				"./packages/ui-extension/src/index.ts"
			],
			"@mcp-vertex/ui-extension/public": [
				"./packages/ui-extension/src/public/index.ts"
			],
			"@mcp-vertex/ui-extension/*": ["./packages/ui-extension/src/*"],
			"@mcp-vertex/shared": ["./apps/shared/src/public/index.ts"],
			"@mcp-vertex/shared/*": ["./apps/shared/src/*"],
			"@mcp-vertex/ide": ["./packages/ui-extension/src/index.ts"],
			"@mcp-vertex/ide/public": [
				"./packages/ui-extension/src/public/index.ts"
			],
			"@mcp-vertex/ide/*": ["./packages/ui-extension/src/*"],
			"@mcp-vertex/proposals": ["./plugins/proposals/src/index.ts"],
			"@mcp-vertex/proposals/public": [
				"./plugins/proposals/src/public/index.ts"
			],
			"@mcp-vertex/proposals/*": ["./plugins/proposals/src/*"],
			"@mcp-vertex/rules": ["./plugins/rules/src/index.ts"],
			"@mcp-vertex/rules/public": ["./plugins/rules/src/public/index.ts"],
			"@mcp-vertex/rules/*": ["./plugins/rules/src/*"],
			"@mcp-vertex/memory": ["./plugins/memory/src/index.ts"],
			"@mcp-vertex/memory/public": [
				"./plugins/memory/src/public/index.ts"
			],
			"@mcp-vertex/memory/*": ["./plugins/memory/src/*"],
			"@mcp-vertex/git": ["./plugins/git/src/index.ts"],
			"@mcp-vertex/git/public": ["./plugins/git/src/public/index.ts"],
			"@mcp-vertex/git/*": ["./plugins/git/src/*"],
			"@mcp-vertex/quality": ["./plugins/quality/src/index.ts"],
			"@mcp-vertex/quality/public": [
				"./plugins/quality/src/public/index.ts"
			],
			"@mcp-vertex/quality/*": ["./plugins/quality/src/*"],
			"@mcp-vertex/search": ["./plugins/search/src/index.ts"],
			"@mcp-vertex/search/public": [
				"./plugins/search/src/public/index.ts"
			],
			"@mcp-vertex/search/*": ["./plugins/search/src/*"],
			"@mcp-vertex/notification": ["./plugins/notification/src/index.ts"],
			"@mcp-vertex/notification/public": [
				"./plugins/notification/src/public/index.ts"
			],
			"@mcp-vertex/notification/*": ["./plugins/notification/src/*"],
			"@mcp-vertex/docs": ["./plugins/docs/src/index.ts"],
			"@mcp-vertex/docs/public": ["./plugins/docs/src/public/index.ts"],
			"@mcp-vertex/docs/*": ["./plugins/docs/src/*"],
			"@mcp-vertex/deps": ["./plugins/deps/src/index.ts"],
			"@mcp-vertex/deps/public": ["./plugins/deps/src/public/index.ts"],
			"@mcp-vertex/deps/*": ["./plugins/deps/src/*"],
			"@mcp-vertex/logs": ["./plugins/logs/src/index.ts"],
			"@mcp-vertex/logs/public": ["./plugins/logs/src/public/index.ts"],
			"@mcp-vertex/logs/*": ["./plugins/logs/src/*"],
			"@mcp-vertex/status-marker": [
				"./plugins/status-marker/src/index.ts"
			],
			"@mcp-vertex/status-marker/public": [
				"./plugins/status-marker/src/public/index.ts"
			],
			"@mcp-vertex/status-marker/*": ["./plugins/status-marker/src/*"],
			"@mcp-vertex/test-convention": [
				"./plugins/test-convention/src/index.ts"
			],
			"@mcp-vertex/test-convention/public": [
				"./plugins/test-convention/src/public/index.ts"
			],
			"@mcp-vertex/test-convention/*": [
				"./plugins/test-convention/src/*"
			],
			"@mcp-vertex/audit": ["./plugins/audit/src/index.ts"],
			"@mcp-vertex/audit/public": ["./plugins/audit/src/public/index.ts"],
			"@mcp-vertex/audit/*": ["./plugins/audit/src/*"],
			"@mcp-vertex/web-fetch": ["./plugins/web-fetch/src/index.ts"],
			"@mcp-vertex/web-fetch/public": [
				"./plugins/web-fetch/src/public/index.ts"
			],
			"@mcp-vertex/web-fetch/*": ["./plugins/web-fetch/src/*"],
			"@mcp-vertex/issues": ["./plugins/issues/src/index.ts"],
			"@mcp-vertex/issues/public": [
				"./plugins/issues/src/public/index.ts"
			],
			"@mcp-vertex/issues/*": ["./plugins/issues/src/*"]
		}
	},
	"exclude": ["node_modules", "dist", "build", ".cache"]
}
